@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}
skinparam package {
    BackgroundColor WhiteSmoke
    BorderColor DarkGray
}

' ── src.operations sub-package ──────────────────────────────────────────────

package "src.operations" {

    class "basic" as BasicOps << (M,orchid) module >> {
        +add(a, b) : number
        +subtract(a, b) : number
        +multiply(a, b) : number
        +divide(a, b) : number
    }
    note right of BasicOps::divide
      Raises ValueError("Division by zero\nis not allowed") when b == 0.
      All functions are pure and stateless.
    end note

    class "scientific" as ScientificOps << (M,orchid) module >> {
        +factorial(n: int) : int
        +square(a) : number
        +cube(a) : number
        +square_root(a) : float
        +cube_root(a) : float
        +power(a, b) : number
        +log(a, base) : float
        +ln(a) : float
    }
    note right of ScientificOps::factorial
      Raises ValueError for non-integer n
      or n < 0. Delegates to math.factorial(n).
    end note
    note right of ScientificOps::square_root
      Raises ValueError if a < 0.
      Delegates to math.sqrt(a).
    end note
    note right of ScientificOps::cube_root
      Supports negative input via
      sign-preserving idiom: -((-a)**(1/3)).
    end note
    note right of ScientificOps::log
      Raises ValueError if a <= 0,
      base <= 0, or base == 1.
      Delegates to math.log(a, base).
    end note
    note right of ScientificOps::ln
      Raises ValueError if a <= 0.
      Delegates to math.log(a).
    end note

}

' ── Calculator class ─────────────────────────────────────────────────────────

class Calculator {
    +add(a, b) : number
    +subtract(a, b) : number
    +multiply(a, b) : number
    +divide(a, b) : number
    +factorial(n: int) : int
    +square(a) : number
    +cube(a) : number
    +square_root(a) : float
    +cube_root(a) : float
    +power(a, b) : number
    +log(a, base) : float
    +ln(a) : float
    +execute(operation: str, *args) : any
}
note right of Calculator::execute
  Dispatches to the named Calculator method
  via getattr(self, operation).
  Raises ValueError for unrecognised or
  non-callable operation names.
  Entry point for all operation dispatch
  from the interface layer (run_operation,
  cli_mode, CalculatorApp._compute).
end note
note right of Calculator
  No state — all methods are pure delegates.
  Imports from src.operations.basic and
  src.operations.scientific.
end note

Calculator ..> BasicOps : delegates add / subtract /\nmultiply / divide
Calculator ..> ScientificOps : delegates factorial / square / cube /\nsquare_root / cube_root / power /\nlog / ln

' ── src.interface sub-package ────────────────────────────────────────────────

package "src.interface" {

    class "history" as History << (M,orchid) module >> {
        +HISTORY_FILE : str = "history.txt"
        +ERROR_LOG_FILE : str = "error.log"
        +clear_history(filepath: str|None) : None
        +append_to_history(entry: str, filepath: str|None) : None
        +show_history(filepath: str|None) : None
        +append_to_error_log(message: str, filepath: str|None) : None
    }
    note right of History::HISTORY_FILE
      Default path for per-session history.
      Cleared at the start of every interactive
      session; NOT written in CLI mode.
      Uses None-sentinel pattern — tests patch
      src.interface.history.HISTORY_FILE.
    end note
    note right of History::ERROR_LOG_FILE
      Append-only error log; never cleared
      across sessions. Stores timestamped
      failure and invalid-input records.
      Uses None-sentinel pattern — tests patch
      src.interface.history.ERROR_LOG_FILE.
    end note
    note right of History::append_to_error_log
      Appends "[YYYY-MM-DD HH:MM:SS] <message>"
      to ERROR_LOG_FILE. Called on:
      — invalid number / integer input
      — invalid menu choice
      — unknown operation in run_operation
      — calculation ValueError in run_operation
      — wrong arg count / non-numeric / calc
        error in cli_mode.
    end note

    class TooManyAttemptsError << (E,red) exception >> {
    }
    note right of TooManyAttemptsError
      Raised by parse_number / parse_int
      after MAX_ATTEMPTS consecutive invalid
      inputs. Propagates out of run_operation
      and is caught in main().
    end note

    class "interactive" as Interactive << (M,orchid) module >> {
        +MAX_ATTEMPTS : int = 3
        +NORMAL_MODE_OPERATIONS : dict[str, str]
        +SCIENTIFIC_MODE_OPERATIONS : dict[str, str]
        +OPERATIONS : dict[str, str]
        +_ONE_ARG_OPS : set
        +_INT_ARG_OPS : set
        +_TWO_ARG_OPS : set
        +_ALL_OPS : set
        +_OP_PROMPTS : dict[str, tuple[str, ...]]
        +show_menu(operations: dict|None, mode: str) : None
        +parse_number(prompt: str, max_attempts: int) : float
        +parse_int(prompt: str, max_attempts: int) : int
        +run_operation(calc: Calculator, operation: str) : str|None
    }
    note right of Interactive::NORMAL_MODE_OPERATIONS
      Maps menu keys "1"–"4" to basic operation
      names: add, subtract, multiply, divide.
      Active in normal mode.
    end note
    note right of Interactive::SCIENTIFIC_MODE_OPERATIONS
      Maps menu keys "1"–"12" to all operation
      names: add, subtract, multiply, divide,
      factorial, square, cube, square_root,
      cube_root, power, log, ln.
      Active in scientific mode.
    end note
    note right of Interactive::OPERATIONS
      Backward-compatible alias for
      SCIENTIFIC_MODE_OPERATIONS. Existing
      code importing OPERATIONS still works.
    end note
    note right of Interactive::_ONE_ARG_OPS
      {square, cube, square_root, cube_root, ln}
      — one float argument.
    end note
    note right of Interactive::_INT_ARG_OPS
      {factorial} — one integer argument.
    end note
    note right of Interactive::_TWO_ARG_OPS
      {add, subtract, multiply, divide,
      power, log} — two float arguments.
    end note
    note right of Interactive::_OP_PROMPTS
      Maps each operation name to a tuple of
      prompt strings (one per required arg).
      Kept in the UI layer so Calculator
      remains free of display concerns.
    end note
    note right of Interactive::show_menu
      Prints header "Calculator (<Mode> Mode)",
      the operations dict entries, and footer
      options h/s/q. When mode=="normal" footer
      shows "switch to scientific mode" and
      vice versa. Defaults to
      NORMAL_MODE_OPERATIONS when operations
      is None.
    end note
    note right of Interactive::parse_number
      Retries up to max_attempts times on
      invalid float input; each failed attempt
      calls append_to_error_log; raises
      TooManyAttemptsError on exhaustion.
    end note
    note right of Interactive::parse_int
      Retries up to max_attempts times on
      non-integer input; each failed attempt
      calls append_to_error_log; raises
      TooManyAttemptsError on exhaustion.
    end note
    note right of Interactive::run_operation
      Returns "op(args) = result" on success;
      returns None on error or unknown op.
      Catches ValueError from Calculator (logs
      to error log). TooManyAttemptsError is
      NOT caught — it propagates to main().
    end note

    class "cli" as CLI << (M,orchid) module >> {
        +cli_mode(args: list[str]) : int
    }
    note right of CLI::cli_mode
      Parses args via argparse.
      Validates arg count and numeric/integer
      format; all errors written to error log
      and printed to stderr.
      Prints result to stdout.
      Returns 0 on success, 1 on error.
      History is NOT written in CLI mode.
    end note

    class CalculatorApp {
        -_mode : str
        -_history : list[str]
        -_history_listbox : Listbox
        -_operations : list[str]
        -_calc : Calculator
        +__init__(root, _tk, _ttk, _messagebox)
        +_build_ui() : None
        +_refresh_operations() : None
        +_on_mode_change() : None
        +_on_operation_select(_event) : None
        +_on_calculate() : None
        +_on_show_history() : None
        +_compute(operation: str, value_a: str, value_b: str) : tuple
    }
    note right of CalculatorApp
      tkinter is NOT imported at module level.
      launch_gui() performs a lazy import and
      passes modules via _tk/_ttk/_messagebox.
      Clears history file at session start.
      Supports normal mode (4 ops) and
      scientific mode (12 ops).
      Layout (cycle 15): outer ttk.Frame with
      four sections — Mode (top), Operation
      listbox (left), stacked Inputs/Result/
      Session History (right), Buttons (bottom).
      _history_listbox is an inline Listbox
      showing session entries in real time.
    end note
    note right of CalculatorApp::_compute
      Pure-logic helper — no tkinter calls.
      Parses string inputs, delegates to
      Calculator.execute, returns (result,
      history_entry) tuple. Raises ValueError
      on parse failures or calculation errors.
    end note
    note right of CalculatorApp::_on_mode_change
      Switches _mode, clears entry fields,
      resets result display, refreshes listbox.
    end note
    note right of CalculatorApp::_on_operation_select
      Adjusts label text (e.g. "Dividend:" /
      "Divisor:" for divide) and shows/hides the
      second input row based on arity.
      One-arg and int-arg ops hide _label_b
      and _entry_b via grid_remove().
    end note
    note right of CalculatorApp::_on_calculate
      Reads widget state, calls _compute,
      updates result display, inserts entry
      into _history_listbox (inline panel),
      appends to in-memory _history list,
      and writes to history file.
      Shows error dialog on ValueError.
    end note
    note right of CalculatorApp::_on_show_history
      Opens a read-only Toplevel window
      listing the session's _history entries.
    end note

    class "gui" as GUI << (M,orchid) module >> {
        +launch_gui() : None
    }
    note right of GUI::launch_gui
      Imports tkinter lazily; creates root
      Tk window; instantiates CalculatorApp
      with injected tk/ttk/messagebox modules;
      calls root.mainloop() (blocks until closed).
    end note

    Interactive ..> History : calls append_to_error_log
    Interactive ..> TooManyAttemptsError : raises
    CLI ..> History : calls append_to_error_log
    CLI ..> Interactive : imports _ONE_ARG_OPS,\n_INT_ARG_OPS, _TWO_ARG_OPS, _ALL_OPS
    CLI ..> Calculator : instantiates + calls execute()
    Interactive ..> Calculator : calls execute() via run_operation
    GUI ..> CalculatorApp : instantiates
    CalculatorApp ..> Calculator : instantiates + calls execute()
    CalculatorApp ..> History : calls clear_history,\nappend_to_history
    CalculatorApp ..> Interactive : imports _ONE_ARG_OPS, _INT_ARG_OPS,\nNORMAL_MODE_OPERATIONS,\nSCIENTIFIC_MODE_OPERATIONS

}

' ── src.__main__ entry point ─────────────────────────────────────────────────

class "__main__" as Main << (M,orchid) module >> {
    +main(args: list[str]|None = None) : None
}
note right of Main
  Top-level entry point. Dispatches to:
  — launch_gui() when args[0] == "--gui"
  — cli_mode(args) when args are present
  — interactive menu loop otherwise.
  Interactive loop tracks mode ("normal" or
  "scientific") and current_ops dict; the "s"
  key toggles between NORMAL_MODE_OPERATIONS
  and SCIENTIFIC_MODE_OPERATIONS.
  Re-exports all public names from interface
  sub-modules for backward compatibility
  (HISTORY_FILE, ERROR_LOG_FILE, MAX_ATTEMPTS,
  NORMAL_MODE_OPERATIONS, SCIENTIFIC_MODE_OPERATIONS,
  OPERATIONS, TooManyAttemptsError, show_menu,
  parse_number, parse_int, run_operation,
  cli_mode, clear_history, append_to_history,
  show_history, append_to_error_log, launch_gui).
  Monkeypatching must target
  src.interface.history, not src.__main__.
end note

Main ..> Calculator : instantiates (interactive mode)
Main ..> Interactive : calls show_menu, run_operation
Main ..> CLI : calls cli_mode
Main ..> History : calls clear_history,\nappend_to_history, show_history,\nappend_to_error_log
Main ..> TooManyAttemptsError : catches in interactive loop
Main ..> GUI : calls launch_gui (--gui mode)

@enduml
