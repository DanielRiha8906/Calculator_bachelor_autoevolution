@startuml class_diagram

package "src" {

    class Calculator {
        +add(a, b) : number
        +subtract(a, b) : number
        +multiply(a, b) : number
        +divide(a, b) : number
        +factorial(n) : int
        +square(x) : float
        +cube(x) : float
        +square_root(x) : float
        +cube_root(x) : float
        +power(base, exp) : float
        +log(x) : float
        +ln(x) : float
    }

    class "__main__" as Main {
        +main() : void
    }

    class "__init__" as Init {
        __all__ : list
    }

}

