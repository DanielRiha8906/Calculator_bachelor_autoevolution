@startuml class_diagram

package "src" {

    class Calculator {
        -_history : list[dict]
        +add(a, b) : number
        +subtract(a, b) : number
        +multiply(a, b) : number
        +divide(a, b) : number
        +factorial(n: int) : int
        +square(x: float) : float
        +cube(x: float) : float
        +square_root(x: float) : float
        +cube_root(x: float) : float
        +power(base: float, exp: float) : float
        +log(x: float) : float
        +ln(x: float) : float
        -_record(operation: str, args: list, result) : void
        +get_history() : list[dict]
        +clear_history() : void
    }

    class "user_input" as UserInput {
        OPERATIONS : dict
        TWO_ARG_OPS : set
        INT_OPS : set
        MAX_RETRIES : int
        +_print_menu() : void
        +_print_history(history: list[dict]) : void
        +_get_float(prompt: str) : float
        +_get_int(prompt: str) : int
        +interactive_mode() : void
    }

    class "cli" as CLI {
        TWO_ARG_OPS : set
        INT_OPS : set
        VALID_OPS : set
        +_build_parser() : ArgumentParser
        +cli_mode(argv: list | None) : int
    }

    class "__main__" as Main {
    }

    class "__init__" as Init {
        __all__ : list
    }

}

