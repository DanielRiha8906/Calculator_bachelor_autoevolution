@startuml class_diagram

title Calculator — Class Diagram

package "src" {
    class Calculator {
        + add(a, b) : float
        + subtract(a, b) : float
        + multiply(a, b) : float
        + divide(a, b) : float
        + factorial(n) : int
        + square(a) : float
        + cube(a) : float
        + square_root(a) : float
        + cube_root(a) : float
        + power(base, exp) : float
        + log(a, base=10) : float
        + ln(a) : float
    }
}

package "controller" {
    class CHOICE_TO_OPERATION <<constant>> {
        dict[str, str]\n"1"→"add" … "12"→"ln"
    }
    class CalculatorController {
        - _calc : Calculator
        + execute(operation, a, b, base) : str
    }
}

package "error_logger" {
    class ERROR_LOG_FILE <<constant>> {
        pathlib.Path("calculator_errors.log")
    }
    class get_error_logger <<function>> {
        + get_error_logger() : Logger
    }
}

package "history" {
    class HISTORY_FILE <<constant>> {
        pathlib.Path("history.txt")
    }
    class clear_history <<function>> {
        + clear_history() : None
    }
    class record_entry <<function>> {
        + record_entry(entry: str) : None
    }
    class load_history <<function>> {
        + load_history() : list[str]
    }
    class display_history <<function>> {
        + display_history() : None
    }
}

package "__main__" {
    class TooManyAttemptsError <<exception>> {
    }
    class display_menu <<function>> {
        + display_menu() : None
    }
    class get_number <<function>> {
        + get_number(prompt: str, max_attempts: int) : float
    }
    class get_integer <<function>> {
        + get_integer(prompt: str, max_attempts: int) : int
    }
    class perform_operation <<function>> {
        + perform_operation(controller: CalculatorController, choice: str) : str | None
    }
    class main <<function>> {
        + main() : None
    }

    TooManyAttemptsError --|> Exception
}

package "cli" {
    class build_parser <<function>> {
        + build_parser() : ArgumentParser
    }
    class _dispatch <<function>> {
        + _dispatch(controller: CalculatorController, args: Namespace) : str
    }
    class cli_main <<function>> {
        + cli_main() : None
    }
}

CalculatorController --> Calculator : uses
CalculatorController ..> CHOICE_TO_OPERATION : defined alongside

main ..> CalculatorController : instantiates
main ..> display_menu : calls
main ..> perform_operation : calls
main ..> clear_history : calls on start
main ..> record_entry : calls after result
main ..> display_history : calls for choice 13
perform_operation ..> get_number : calls
perform_operation ..> get_integer : calls
perform_operation ..> CalculatorController : dispatches to
get_number ..> TooManyAttemptsError : raises
get_integer ..> TooManyAttemptsError : raises
display_history ..> load_history : calls
record_entry ..> HISTORY_FILE : appends to
clear_history ..> HISTORY_FILE : clears
load_history ..> HISTORY_FILE : reads

cli_main ..> build_parser : calls
cli_main ..> CalculatorController : instantiates
cli_main ..> _dispatch : calls
cli_main ..> get_error_logger : calls on error
_dispatch ..> CalculatorController : dispatches to

main ..> get_error_logger : calls on error
perform_operation ..> get_error_logger : calls on invalid log base
get_error_logger ..> ERROR_LOG_FILE : writes to

note bottom of main
  Entry point selects mode:
  - no args  → interactive (main)
  - with args → bash CLI (cli_main)
end note

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::factorial
  Raises ValueError when n < 0
  or n is not an integer
end note

note right of Calculator::square_root
  Raises ValueError when a < 0
end note

note right of Calculator::log
  Raises ValueError when a <= 0
end note

note right of Calculator::ln
  Raises ValueError when a <= 0
end note

note right of CalculatorController::execute
  Raises ValueError for unknown operation.
  Propagates ValueError / ZeroDivisionError
  from Calculator to the caller.
end note

@enduml
