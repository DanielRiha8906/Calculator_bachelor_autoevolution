@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}

class Calculator {
    +add(a, b) : number
    +subtract(a, b) : number
    +multiply(a, b) : number
    +divide(a, b) : number
    +factorial(n: int) : int
    +square(a) : number
    +cube(a) : number
    +square_root(a) : float
    +cube_root(a) : float
    +power(a, b) : number
    +log(a, base) : float
    +ln(a) : float
}

note right of Calculator::divide
  Raises ValueError if b == 0
end note

note right of Calculator::factorial
  Raises ValueError if n < 0
  or n is not an integer.
  Delegates to math.factorial(n).
end note

note right of Calculator::square_root
  Raises ValueError if a < 0
end note

note right of Calculator::log
  Raises ValueError if a <= 0,
  base <= 0, or base == 1
end note

note right of Calculator::ln
  Raises ValueError if a <= 0.
  Delegates to math.log(a).
end note

class "__main__" as Main {
    +OPERATIONS : dict
    +show_menu() : None
    +parse_number(prompt: str) : float
    +parse_int(prompt: str) : int
    +run_operation(calc: Calculator, operation: str) : None
    +main() : None
}

note right of Main::OPERATIONS
  Maps keys "1"-"12" to operation names:
  add, subtract, multiply, divide,
  factorial, square, cube, square_root,
  cube_root, power, log, ln
end note

note right of Main::parse_number
  Retries indefinitely on
  invalid float input
end note

note right of Main::parse_int
  Retries indefinitely on
  non-integer input
end note

note right of Main::run_operation
  Catches ValueError from Calculator
  and prints the error message;
  loop always continues.
end note

Main ..> Calculator : instantiates
Main ..> Calculator : delegates operations to

@enduml
