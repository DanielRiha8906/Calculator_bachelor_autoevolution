@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold

package "src" {

    package "operations" {
        class BasicOperations {
            +add(a, b) : float|int
            +subtract(a, b) : float|int
            +multiply(a, b) : float|int
            +divide(a, b) : float|int
        }

        class ScientificOperations {
            +factorial(n: int) : int
            +square(x) : float
            +cube(x) : float
            +square_root(x) : float
            +cube_root(x) : float
            +power(base, exp) : float
            +log(x) : float
            +ln(x) : float
            +sin(x) : float
            +cos(x) : float
            +tan(x) : float
            +cot(x) : float
            +asin(x) : float
            +acos(x) : float
        }

        class "operations/__init__" as OpsInit <<module>> {
            __all__ : list
        }
    }

    class Calculator {
        ' No methods defined directly on Calculator.
        ' All 18 ops are inherited via MRO:
        ' Calculator → BasicOperations → ScientificOperations → object
    }

    class CalculatorSession {
        -{field} _calc : Calculator
        -{field} _history : list[str]
        +BINARY_OPS : frozenset[str]  <<module constant>>
        +UNARY_OPS : frozenset[str]   <<module constant>>
        +ALL_OPS : frozenset[str]     <<module constant>>
        +__init__() : None
        +execute(name: str, *args) : float|int
        +{static} format_entry(name, args, result) : str
        +history() : list[str]
        +save(path: str) : None
    }

    class "__main__" as Main <<module>> {
        +NORMAL_OPERATIONS : dict[str, tuple[str, int]]
        +SCIENTIFIC_OPERATIONS : dict[str, tuple[str, int]]
        +MAX_ATTEMPTS : int
        +HISTORY_FILE : str
        +display_menu(operations, mode_name) : None
        +get_number(prompt, require_int=False) : int|float
        +get_number_with_retry(prompt, require_int=False) : int|float
        +format_history_entry(name, args, result) : str
        +save_history(history, path=None) : None
        +main() : None
        -{static} _SessionExpired <<exception>>
    }

    class "error_logger" as ErrLog <<module>> {
        +ERROR_LOG_FILE : str
        +log_error(source: str, message: str) : None
    }

    class "__init__" as Init <<module>> {
        __all__ : list
    }

    package "gui.py" {
        class _SectionFrame <<ttk.LabelFrame>> {
            +__init__(parent: tk.Widget, title: str)
        }

        class ModeSelector {
            -{field} _var : tk.StringVar
            -{field} _frame : _SectionFrame
            +frame : _SectionFrame
            +__init__(parent, mode_var, on_change) : None
        }

        class OperationSelector {
            -{field} _mode_var : tk.StringVar
            -{field} _op_type_var : tk.StringVar
            -{field} _op_name_var : tk.StringVar
            -{field} _frame : _SectionFrame
            -{field} _combo : ttk.Combobox
            +frame : _SectionFrame
            +__init__(parent, mode_var, op_type_var, op_name_var, on_arity_change) : None
            +refresh_for_mode() : None
        }

        class OperandSection {
            -{field} _a_var : tk.StringVar
            -{field} _b_var : tk.StringVar
            -{field} _frame : _SectionFrame
            +frame : _SectionFrame
            +__init__(parent, operand_a_var, operand_b_var) : None
            +set_binary_mode(is_binary, op_name) : None
            +get_operands(op_name) : tuple
        }

        class ResultDisplay {
            -{field} _frame : _SectionFrame
            -{field} _label : tk.Label
            +frame : _SectionFrame
            +__init__(parent) : None
            +show_result(value) : None
            +show_error(message: str) : None
            +clear() : None
        }

        class HistoryPanel {
            -{field} _frame : _SectionFrame
            -{field} _text : tk.Text
            +frame : _SectionFrame
            +__init__(parent) : None
            +refresh(entries: list[str]) : None
            +clear() : None
        }

        class CalculatorGUI {
            -{field} _root : tk.Tk
            -{field} _session : CalculatorSession
            -{field} _mode_var : tk.StringVar
            -{field} _op_type_var : tk.StringVar
            -{field} _op_name_var : tk.StringVar
            -{field} _operand_a_var : tk.StringVar
            -{field} _operand_b_var : tk.StringVar
            -{field} _mode_section : ModeSelector
            -{field} _op_section : OperationSelector
            -{field} _operand_section : OperandSection
            -{field} _result_section : ResultDisplay
            -{field} _history_section : HistoryPanel
            +__init__(root: tk.Tk) : None
            -_on_mode_change() : None
            -_on_arity_change() : None
            -_on_calculate() : None
            -_on_clear() : None
        }

        class "gui" as Gui <<module>> {
            +_parse_number(raw: str) : int|float
            +main() : None
        }
    }
}

class "main" as CLI <<module>> {
    +_parse_operand(value: str, require_int=False) : int|float
    +main(argv: list[str] | None) : int
}

class "gui_main" as GUIMain <<module>> {
    ' Entry point: python gui_main.py
    ' No logic; delegates entirely to src.gui.main()
}

