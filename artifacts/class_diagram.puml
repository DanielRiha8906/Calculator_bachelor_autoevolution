@startuml class_diagram

title Calculator — Class Diagram

package "src" {

    package "src.operations" {

        class BasicOperations <<mixin>> {
            + add(a, b) : number
            + subtract(a, b) : number
            + multiply(a, b) : number
            + divide(a, b) : number
        }

        class ScientificOperations <<mixin>> {
            + factorial(n: int) : int
            + square(n) : number
            + cube(n) : number
            + sqrt(n) : float
            + cbrt(n) : float
            + power(base, exp) : float
            + log10(n) : float
            + ln(n) : float
            + sin(angle_deg) : float
            + cos(angle_deg) : float
            + tan(angle_deg) : float
            + cot(angle_deg) : float
            + asin(x) : float
            + acos(x) : float
        }

        class "__init__" as OpsInit <<module>> {
            + __all__ : list
        }

    }

    class Calculator {
        ' All public methods inherited via multiple inheritance
        ' from BasicOperations and ScientificOperations
    }

    ' ── GUI layer ────────────────────────────────────────────────────────────

    class OperationSpec <<dataclass>> {
        + name : str
        + method : str
        + arity : int
        + label_a : str
        + label_b : str
        + require_int : bool
    }

    abstract class CalculatorMode <<ABC>> {
        {abstract} + name : str
        {abstract} + operations : list[OperationSpec]
    }

    class SimpleMode {
        + name : str
        + operations : list[OperationSpec]
    }

    class ScientificMode {
        + name : str
        + operations : list[OperationSpec]
    }

    class "gui_modes" as GuiModes <<module>> {
        + parse_number(text: str, require_int: bool) : int | float
    }

    class CalculatorApp <<tk.Tk>> {
        - calculator : Calculator
        - modes : list[CalculatorMode]
        - current_mode : CalculatorMode
        - history : list[str]
        - mode_var : tk.StringVar
        - op_var : tk.StringVar
        - op_combo : ttk.Combobox
        - label_a : ttk.Label
        - label_b : ttk.Label
        - entry_a : ttk.Entry
        - entry_b : ttk.Entry
        - result_var : tk.StringVar
        - history_listbox : tk.Listbox
        + __init__()
        - _build_ui() : void
        - _build_mode_frame() : void
        - _build_operation_frame() : void
        - _build_input_frame() : void
        - _build_result_frame() : void
        - _build_buttons() : void
        - _build_history_frame() : void
        - _on_mode_change() : void
        - _on_operation_change(_event) : void
        - _refresh_operations() : void
        - _selected_operation() : OperationSpec | None
        - _update_inputs(op: OperationSpec) : void
        - _calculate() : void
        - _clear() : void
    }

    class "gui" as GuiMod <<module>> {
        + run() : void
    }

    ' ── CLI layer ─────────────────────────────────────────────────────────────

    class InteractiveSession {
        - _calc : Calculator
        - _history : list[str]
        - _menu_failures : int
        - _mode : str
        + __init__(calc: Calculator | None)
        + run() : void
        - _select_mode() : str | None
        - _display_menu() : void
        - _show_history() : void
        - _handle_operation(choice: str) : bool
    }

    class "session" as Sess <<module>> {
        + MAX_RETRIES : int
        + HISTORY_FILE : str
        + NORMAL_OPERATIONS : dict
        + SCIENTIFIC_OPERATIONS : dict
        + _format_history_entry(op_name: str, operands: tuple, result) : str
        + _write_history(history: list[str]) : void
        + _parse_number(prompt: str, require_int: bool) : int | float
        + _prompt_number(prompt: str, require_int: bool) : int | float | None
    }

    class CLIHandler {
        - _calc : Calculator
        + __init__(calc: Calculator | None)
        + run(argv: list[str]) : void
    }

    class "cli" as CLI <<module>> {
        + CLI_OPERATIONS : dict
        + USAGE : str
        + _parse_operand(value: str, require_int: bool) : int | float
    }

    class "__main__" as Main <<module>> {
        + MAX_RETRIES : int
        + main() : void
    }

    class "__init__" as Init <<module>> {
        + __all__ : list
    }

    class "error_logger" as ErrLog <<module>> {
        + ERROR_LOG_FILE : str
        + setup_error_logging(log_file: str) : void
        + get_error_logger() : Logger
    }

}

package "root" {

    class "main" as RootMain <<module>> {
        + main(argv: list | None) : void
    }

}

' ── Inheritance ───────────────────────────────────────────────────────────────

BasicOperations <|-- Calculator
ScientificOperations <|-- Calculator

CalculatorMode <|-- SimpleMode
CalculatorMode <|-- ScientificMode
CalculatorMode "1" *-- "many" OperationSpec : returns list of

' ── GUI relationships ──────────────────────────────────────────────────────────

CalculatorApp o-- Calculator : holds reference
CalculatorApp o-- "1..*" CalculatorMode : modes list
CalculatorApp --> OperationSpec : uses per selected op
CalculatorApp --> ErrLog : (indirectly, via Calculator errors\ncaught in _calculate())
GuiMod --> CalculatorApp : run() instantiates & mainloop()
GuiModes --> OperationSpec : module context
GuiModes --> CalculatorMode : module context

' ── Interactive session relationships ─────────────────────────────────────────

InteractiveSession o-- Calculator : holds reference\n(creates if None)
InteractiveSession --> ErrLog : run() calls setup_error_logging()\n_handle_operation() / _prompt_number()\n  call get_error_logger()
Sess --> InteractiveSession : contains class definition
Main --> InteractiveSession : main() instantiates & calls run()
Main ..> Sess : re-exports MAX_RETRIES

' ── CLI relationships ─────────────────────────────────────────────────────────

CLIHandler o-- Calculator : holds reference\n(creates if None)
CLIHandler --> ErrLog : run() calls get_error_logger()
CLI --> CLIHandler : contains class definition
RootMain --> CLIHandler : main() instantiates & calls run()
RootMain --> ErrLog : main() calls setup_error_logging()

Init ..> Calculator : exports
OpsInit ..> BasicOperations : exports
OpsInit ..> ScientificOperations : exports

' ── Notes ─────────────────────────────────────────────────────────────────────

note right of BasicOperations
  Mixin providing the four standard arithmetic
  operations. Defined in src/operations/basic.py.
  Combined with ScientificOperations via
  multiple inheritance in Calculator.
  divide: Raises ZeroDivisionError when b == 0.
end note

note right of ScientificOperations
  Mixin providing advanced mathematical operations.
  Defined in src/operations/scientific.py.
  Combined with BasicOperations via
  multiple inheritance in Calculator.
  All trigonometric functions accept and
  return values in degrees.
end note

note right of ScientificOperations::factorial
  Raises TypeError for non-integers
  (including bool).
  Raises ValueError for n < 0.
  Delegates to math.factorial(n).
end note

note right of ScientificOperations::sqrt
  Raises ValueError for n < 0.
  Delegates to math.sqrt(n).
end note

note right of ScientificOperations::cbrt
  Defined for all real numbers.
  Negative input yields negative result.
  Delegates to math.cbrt(n).
end note

note right of ScientificOperations::power
  Raises ValueError when result is complex
  (negative base, non-integer exponent).
  Delegates to math.pow(base, exp).
end note

note right of ScientificOperations::log10
  Raises ValueError for n <= 0.
  Delegates to math.log10(n).
end note

note right of ScientificOperations::ln
  Raises ValueError for n <= 0.
  Delegates to math.log(n).
end note

note right of ScientificOperations::sin
  Returns sin(angle_deg) via math.sin(radians).
end note

note right of ScientificOperations::cos
  Returns cos(angle_deg) via math.cos(radians).
end note

note right of ScientificOperations::tan
  Raises ValueError at odd multiples of 90°
  (undefined). Delegates to math.tan(radians).
end note

note right of ScientificOperations::cot
  Raises ValueError at multiples of 180°
  (undefined). Computed as 1/tan(radians).
end note

note right of ScientificOperations::asin
  Raises ValueError for x outside [-1, 1].
  Returns result in degrees.
end note

note right of ScientificOperations::acos
  Raises ValueError for x outside [-1, 1].
  Returns result in degrees.
end note

note right of Calculator
  Full-featured calculator composing basic and
  scientific operations via multiple inheritance.
  Defined in src/calculator.py.
  Has no methods of its own — the full public API
  is supplied by the two mixin parent classes.
end note

note right of OperationSpec
  Dataclass describing one operation in the GUI.
  name: display name in the combobox.
  method: Calculator method to invoke.
  arity: 1 (unary) or 2 (binary).
  label_a/label_b: input field labels.
  require_int: True forces integer parse (factorial).
end note

note right of CalculatorMode
  Abstract base class for GUI modes.
  Concrete subclasses expose name and
  an ordered list of OperationSpec objects.
  The GUI switches between modes without
  knowing operation specifics.
end note

note right of SimpleMode
  Normal arithmetic mode.
  Provides 6 operations:
  Add, Subtract, Multiply, Divide,
  Square, Square Root.
end note

note right of ScientificMode
  Scientific mode.
  Provides 12 operations:
  Power, Cube, Cube Root, Factorial,
  Log10, Ln, Sin, Cos, Tan, Cot,
  Arcsin, Arccos.
  All trig operations expect angles in degrees.
end note

note right of GuiModes::parse_number
  Parses a GUI input field string into a number.
  Returns int for whole-number text, float otherwise.
  When require_int=True, a non-integer value
  (e.g. "3.5") raises ValueError.
  Raises ValueError for empty or non-numeric input.
end note

note right of CalculatorApp
  Main tkinter window (extends tk.Tk).
  Defined in src/gui.py.
  Supports Simple and Scientific modes via
  CalculatorMode abstractions. Operation selector
  dynamically shows/hides the second input field
  based on OperationSpec.arity. Results and session
  history are displayed in the window.
  Launch via python -m src.gui or src.gui.run().
end note

note right of CalculatorApp::_calculate
  Reads entry_a (and entry_b when arity==2).
  Calls parse_number() for type coercion.
  Resolves Calculator method via getattr().
  Catches ValueError, ZeroDivisionError, OverflowError.
  Displays result; appends formatted entry to history.
end note

note right of CalculatorApp::_refresh_operations
  Called on mode change.
  Repopulates op_combo with the current mode's
  operation names.
  Selects the first operation and updates inputs.
  Resets result display to em-dash.
end note

note right of InteractiveSession::_calc
  Injected via constructor or created fresh.
  Allows Calculator to be exercised
  independently of the interactive UI
  (e.g. in tests).
end note

note right of InteractiveSession::_history
  In-memory list of formatted strings for
  successful calculations in the session.
  Written to HISTORY_FILE on every exit path.
end note

note right of InteractiveSession::_menu_failures
  Counts consecutive invalid menu choices.
  Resets to 0 on a valid choice.
  Session terminates after MAX_RETRIES failures.
end note

note right of InteractiveSession::_mode
  Set by _select_mode() at the start of run()
  and updated whenever the user presses 's'.
  Determines which operations dict is active:
  NORMAL_OPERATIONS or SCIENTIFIC_OPERATIONS.
end note

note right of InteractiveSession::_select_mode
  Prompts for mode selection (1=Normal, 2=Scientific).
  Retries up to MAX_RETRIES on invalid input.
  Returns "normal" or "scientific" on success,
  or None when retries are exhausted (ends session).
end note

note right of InteractiveSession::run
  Main session loop.
  Calls setup_error_logging() on startup.
  Calls _select_mode() before entering the loop.
  Supports 's' key for mid-session mode switching.
  Delegates menu display to _display_menu(),
  history display to _show_history(), and
  operation execution to _handle_operation().
  Writes history to HISTORY_FILE on every exit.
end note

note right of InteractiveSession::_handle_operation
  Collects operands via _prompt_number().
  Returns False when retries are exhausted
  (signals run() to terminate the session).
  Returns True to continue the loop.
end note

note right of CLIHandler::_calc
  Injected via constructor or created fresh.
  Allows Calculator to be exercised
  independently of CLI concerns (e.g. in tests).
end note

note right of CLIHandler::run
  Validates argv: checks operation exists,
  operand count, and parses operand types.
  Logs each error via get_error_logger()
  with [cli] prefix.
  Prints result to stdout; errors to stderr.
  Exits with code 1 on any failure.
  No retry — fails fast on invalid input.
end note

note right of CLI::CLI_OPERATIONS
  Maps operation name -> (method_name, arity).
  Covers all 12 Calculator operations.
  Used to validate and dispatch CLI arguments.
end note

note right of CLI::_parse_operand
  Parses a CLI argument string into a number.
  Returns int for whole-number input, float otherwise.
  When require_int=True, parses strictly as int
  (used for factorial); raises ValueError otherwise.
end note

note right of RootMain::main
  Bash CLI entry point (main.py at project root).
  Calls setup_error_logging() on startup.
  Delegates all logic to src.cli.CLIHandler().run(argv).
end note

note right of Sess::MAX_RETRIES
  Maximum consecutive invalid inputs
  allowed before the session terminates.
  Applies to both menu selection and
  operand entry.
end note

note right of Sess::HISTORY_FILE
  Path to the file where session history
  is written when the session ends.
  Default: "history.txt" in the working directory.
  Each session overwrites the file.
end note

note right of Sess::NORMAL_OPERATIONS
  Maps menu key -> (method_name, label, arity).
  Keys "1"–"6": add, subtract, multiply, divide,
  square, sqrt. Shown in Normal mode.
end note

note right of Sess::SCIENTIFIC_OPERATIONS
  Maps menu key -> (method_name, label, arity).
  Keys "1"–"12": power, cube, cbrt, factorial,
  log10, ln, sin, cos, tan, cot, asin, acos.
  Shown in Scientific mode. All trig in degrees.
end note

note right of Sess::_format_history_entry
  Formats one history entry in function-style notation.
  Binary example: add(2, 3) = 5
  Unary example:  sqrt(9) = 3.0
end note

note right of Sess::_write_history
  Writes all history entries to HISTORY_FILE,
  one entry per line.  Always overwrites the file
  so each new session starts with a clean slate on disk.
end note

note right of Sess::_parse_number
  Reads a number from stdin.
  Returns int for whole-number input,
  float otherwise.
  When require_int=True, parses strictly
  as int (used for factorial).
end note

note right of Sess::_prompt_number
  Wraps _parse_number with retry logic.
  Re-prompts up to MAX_RETRIES times on
  invalid (unparseable) input, showing
  remaining attempts.
  Logs each invalid input via get_error_logger()
  with [interactive] prefix.
  Returns None when retries are exhausted.
end note

note right of Main::main
  Thin entry point for interactive mode
  (src/__main__.py).
  Instantiates InteractiveSession and calls run().
  Re-exports MAX_RETRIES from src.session for
  import compatibility.
end note

note right of ErrLog::ERROR_LOG_FILE
  Default path for the error log file.
  Value: "error.log" in the working directory.
end note

note right of ErrLog::setup_error_logging
  Attaches a FileHandler to the shared logger.
  Safe to call multiple times — handler added only once.
  Called at application startup inside main().
  Can be patched in tests to prevent file side-effects.
end note

note right of ErrLog::get_error_logger
  Returns the shared "calculator.errors" Logger.
  Level is set to ERROR at import time so
  pytest caplog can capture records in tests.
  Logged events are tagged [cli] or [interactive].
end note

@enduml
