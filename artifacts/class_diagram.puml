@startuml class_diagram

title Calculator — Class Diagram

package "src" {

    class Calculator {
        + add(a, b) : float
        + subtract(a, b) : float
        + multiply(a, b) : float
        + divide(a, b) : float
        --
        + factorial(n : int) : int
        + square(x) : float
        + cube(x) : float
        + sqrt(x) : float
        + cbrt(x) : float
        + power(base, exp) : float
        + log(x) : float
        + ln(x) : float
    }

    note right of Calculator
        All methods are stateless.
        Errors raised as ValueError
        with descriptive messages:
          - divide(x, 0) → "Cannot divide by zero"
          - sqrt(-1) → "Cannot take sqrt of negative"
          - log(0) → "Cannot take log of non-positive"
          - factorial(-1) → "n must be a non-negative integer"
    end note

    class "__main__" as Main {
        + HISTORY_FILE : str
        + MAX_ATTEMPTS : int
        + main() : None
        + run_calculator(input_fn, print_fn, history_file) : None
        + run_bash_mode(args, print_fn) : int
        - _parse_float(s : str) : float
        - _clear_history(path : str) : None
        - _append_history(path : str, entry : str) : None
        - _show_history(path : str, print_fn) : None
    }

    note right of Main
        history_file defaults to HISTORY_FILE.
        Cleared at session start; each successful
        operation is appended. 'h' in interactive
        mode displays current session history.
        Bash mode does not record history.
    end note

    Main --> Calculator : uses
}

@enduml
