@startuml class_diagram

title Calculator — Class Diagram

package "src" {
    class Calculator {
        + add(a, b) : float
        + subtract(a, b) : float
        + multiply(a, b) : float
        + divide(a, b) : float
        + factorial(n) : int
    }
}

package "__main__" {
    class main <<function>> {
        + main() : None
    }
}

main ..> Calculator : instantiates

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::factorial
  Raises ValueError when n < 0
  or n is not an integer
end note

@enduml
