@startuml class_diagram

title Calculator — Class Diagram

package "src" {

    class Calculator {
        + add(a, b) : float
        + subtract(a, b) : float
        + multiply(a, b) : float
        + divide(a, b) : float
        --
        + factorial(n : int) : int
        + square(x) : float
        + cube(x) : float
        + sqrt(x) : float
        + cbrt(x) : float
        + power(base, exp) : float
        + log(x) : float
        + ln(x) : float
    }

    note right of Calculator
        All methods are stateless.
        Error types and messages:
          - divide(x, 0) → ZeroDivisionError("division by zero")
          - sqrt(x<0) → ValueError("Square root is not defined for negative numbers")
          - cbrt: no error (supports negatives via math.cbrt)
          - log(x≤0) → ValueError("Logarithm is not defined for non-positive numbers")
          - ln(x≤0) → ValueError("Natural logarithm is not defined for non-positive numbers")
          - factorial(non-int) → ValueError("Factorial requires a non-negative integer")
          - factorial(n<0) → ValueError("Factorial is not defined for negative numbers")
    end note

    class "__main__" as Main {
        + OPERATIONS : dict
        + OP_BY_NAME : dict
        + HISTORY_FILE : str
        + ERROR_LOG_FILE : str
        + MAX_ATTEMPTS : int
        + main() : None
        + run_calculator(input_fn, print_fn, history_file, error_log_file) : None
        + run_bash_mode(args, print_fn, error_log_file) : int
        - _parse_float(s : str) : float
        - _log_error(path : str, message : str) : None
        - _clear_history(path : str) : None
        - _append_history(path : str, entry : str) : None
        - _show_history(path : str, print_fn) : None
    }

    note right of Main
        OPERATIONS maps choice keys ("1"-"12") to
        (method_name, num_args, label) tuples.
        OP_BY_NAME maps method_name → num_args
        for bash mode lookup.
        history_file defaults to HISTORY_FILE.
        Cleared at session start; each successful
        operation is appended. 'h' in interactive
        mode displays current session history.
        Bash mode does not record history.
        error_log_file defaults to ERROR_LOG_FILE.
        Invalid choices, invalid operands, and
        calculation errors (ValueError, ZeroDivisionError)
        are appended as timestamped entries.
    end note

    Main --> Calculator : uses
}

@enduml
