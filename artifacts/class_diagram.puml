@startuml class_diagram

title Calculator — Class Diagram

package "src" {

    class Calculator {
        + add(a, b) : number
        + subtract(a, b) : number
        + multiply(a, b) : number
        + divide(a, b) : number
        + factorial(n: int) : int
    }

    class "__main__" as Main <<module>> {
        + main() : void
    }

    class "__init__" as Init <<module>> {
        + __all__ : list
    }

}

Main --> Calculator : instantiates & calls
Init ..> Calculator : exports

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::factorial
  Raises TypeError for non-integers
  (including bool).
  Raises ValueError for n < 0.
  Delegates to math.factorial(n).
end note

@enduml
