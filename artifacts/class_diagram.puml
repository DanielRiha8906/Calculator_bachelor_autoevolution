@startuml class_diagram

title Calculator — Class Diagram

package "src" {
    class Calculator {
        +add(a, b) : number
        +subtract(a, b) : number
        +multiply(a, b) : number
        +divide(a, b) : number
        +factorial(n) : int
        +square(n) : number
        +cube(n) : number
        +square_root(n) : float
        +cube_root(n) : float
        +power(base, exp) : number
        +log(n) : float
        +ln(n) : float
    }

    class "__main__" as Main <<module>> {
        +main() : void
    }
}

Main ..> Calculator : instantiates

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0 (Python built-in)
end note

note right of Calculator::factorial
  Delegates to math.factorial(n)
  Raises ValueError for n < 0
end note

note right of Calculator::square_root
  Delegates to math.sqrt(n)
  Raises ValueError for n < 0
end note

note right of Calculator::cube_root
  Delegates to math.cbrt(n)
  Handles negative inputs
  Requires Python 3.11+
end note

note right of Calculator::log
  Delegates to math.log10(n)
  Raises ValueError for n <= 0
end note

note right of Calculator::ln
  Delegates to math.log(n)
  Raises ValueError for n <= 0
end note

@enduml
