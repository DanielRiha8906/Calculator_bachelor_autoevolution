@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold

package "src" {

    package "operations" {
        class BasicOperations {
            +add(a, b) : float|int
            +subtract(a, b) : float|int
            +multiply(a, b) : float|int
            +divide(a, b) : float|int
        }

        class ScientificOperations {
            +factorial(n: int) : int
            +square(x) : float
            +cube(x) : float
            +square_root(x) : float
            +cube_root(x) : float
            +power(base, exp) : float
            +log(x) : float
            +ln(x) : float
            +sin(x) : float
            +cos(x) : float
            +tan(x) : float
            +cot(x) : float
            +asin(x) : float
            +acos(x) : float
        }

        class "operations/__init__" as OpsInit <<module>> {
            __all__ : list
        }
    }

    class Calculator {
        ' No methods defined directly on Calculator.
        ' All 18 ops are inherited via MRO:
        ' Calculator → BasicOperations → ScientificOperations → object
    }

    class CalculatorSession {
        -{field} _calc : Calculator
        -{field} _history : list[str]
        +BINARY_OPS : frozenset[str]  <<module constant>>
        +UNARY_OPS : frozenset[str]   <<module constant>>
        +ALL_OPS : frozenset[str]     <<module constant>>
        +__init__() : None
        +execute(name: str, *args) : float|int
        +{static} format_entry(name, args, result) : str
        +history() : list[str]
        +save(path: str) : None
    }

    class "__main__" as Main <<module>> {
        +NORMAL_OPERATIONS : dict[str, tuple[str, int]]
        +SCIENTIFIC_OPERATIONS : dict[str, tuple[str, int]]
        +MAX_ATTEMPTS : int
        +HISTORY_FILE : str
        +display_menu(operations, mode_name) : None
        +get_number(prompt, require_int=False) : int|float
        +get_number_with_retry(prompt, require_int=False) : int|float
        +format_history_entry(name, args, result) : str
        +save_history(history, path=None) : None
        +main() : None
        -{static} _SessionExpired <<exception>>
    }

    class "error_logger" as ErrLog <<module>> {
        +ERROR_LOG_FILE : str
        +log_error(source: str, message: str) : None
    }

    class "__init__" as Init <<module>> {
        __all__ : list
    }

    ' ---------------------------------------------------------------
    ' GUI layer (cycles 15-16)
    ' ---------------------------------------------------------------

    package "gui_modes" {
        abstract class CalculatorMode <<ABC>> {
            {abstract} +name : str <<property>>
            {abstract} +operations : dict[str, tuple[str, int]] <<property>>
        }

        class SimpleMode {
            +name : str <<property>>
            +operations : dict[str, tuple[str, int]] <<property>>
            ' 6 ops: add, subtract, multiply, divide,
            '        square, square_root
        }

        class ScientificMode {
            +name : str <<property>>
            +operations : dict[str, tuple[str, int]] <<property>>
            ' 18 ops: all SimpleMode ops plus
            '   factorial, cube, cube_root, power, log, ln,
            '   sin, cos, tan, cot, asin, acos
        }

        class "parse_number" as ParseNumber <<function>> {
            +parse_number(raw: str) : int|float
        }
    }

    class _OperandSection {
        -{field} _entry_a : ttk.Entry
        -{field} _entry_b : ttk.Entry
        -{field} _label_b : ttk.Label
        -{field} _arity : int
        -{field} _frame : ttk.LabelFrame
        +__init__(parent: tk.Widget) : None
        +set_arity(arity: int) : None
        +clear() : None
        +read_a() : str
        +read_b() : str
        +focus_a() : None
    }

    class CalculatorGUI {
        -{field} _root : tk.Tk
        -{field} _session : CalculatorSession
        -{field} _modes : list[CalculatorMode]
        -{field} _current_mode : CalculatorMode
        -{field} _operand_section : _OperandSection
        -{field} _mode_var : tk.StringVar
        -{field} _op_var : tk.StringVar
        -{field} _op_combo : ttk.Combobox
        -{field} _arity_label_var : tk.StringVar
        -{field} _result_var : tk.StringVar
        -{field} _history_box : scrolledtext.ScrolledText
        +__init__(root: tk.Tk) : None
        -_setup_ui() : None
        -_build_mode_section() : None
        -_build_operation_section() : None
        -_build_action_section() : None
        -_build_result_section() : None
        -_build_history_section() : None
        -_refresh_operations() : None
        -_apply_operation(display_name: str) : None
        -_refresh_history_display() : None
        -_on_mode_change() : None
        -_on_op_selected(_event) : None
        -_on_clear() : None
        -_on_calculate() : None
    }

    class "gui" as GUIModule <<module>> {
        +main() : None
        ' Re-exports: CalculatorMode, SimpleMode, ScientificMode
    }
}

class "main" as CLI <<module>> {
    +_parse_operand(value: str, require_int=False) : int|float
    +main(argv: list[str] | None) : int
}

class "gui" as GUILauncher <<module>> {
    ' Thin root-level launcher: calls src.gui.main()
}

package "tests" {
    class "test_calculator" as TestCalc <<module>> {
        +calc() : Calculator  <<fixture>>
        ' 76 tests covering all 18 operations
        +test_add_*()
        +test_subtract_*()
        +test_multiply_*()
        +test_divide_*()
        +test_factorial_*()
        +test_square_*()
        +test_cube_*()
        +test_square_root_*()
        +test_cube_root_*()
        +test_power_*()
        +test_log_*()
        +test_ln_*()
    }

    class "test_session" as TestSession <<module>> {
        +session() : CalculatorSession  <<fixture>>
        ' 49 tests covering CalculatorSession
        +test_op_sets_*()
        +test_format_entry_*()
        +test_execute_*()
        +test_history_*()
        +test_save_*()
    }

    class "test_main" as TestMain <<module>> {
        +run_main_with_inputs(inputs) : list[str]  <<helper>>
        ' 80+ tests covering interactive CLI
        +test_operations_map_*()
        +test_mode_switching_*()
        +test_get_number_*()
        +test_quit_*()
        +test_all_18_ops_end_to_end_*()
        +test_trig_ops_*()
        +test_error_paths_*()
        +test_unknown_key()
        +test_multi_session_*()
        +test_format_history_entry_*()
        +test_save_history_*()
        +test_history_display_*()
        +test_history_file_written_*()
    }

    class "test_cli" as TestCLI <<module>> {
        +run_cli(args) : tuple[int, str, str]  <<helper>>
        ' 34 tests covering bash CLI
        +test_no_args()
        +test_unknown_op()
        +test_arg_count_binary_*()
        +test_arg_count_unary_*()
        +test_all_12_ops_*()
        +test_error_paths_*()
        +test_non_numeric_operand()
    }

    class "test_error_logger" as TestErrLog <<module>> {
        ' 7 tests covering error_logger
        +test_file_created()
        +test_source_and_message()
        +test_timestamp_format()
        +test_append_behavior()
        +test_one_entry_per_line()
    }

    class "test_gui" as TestGUI <<module>> {
        ' 42 tests covering gui_modes (no display required)
        +test_mode_abc_*()
        +test_simple_mode_*()
        +test_scientific_mode_*()
        +test_parse_number_*()
        +test_mode_contract_*()
    }

    class "conftest" as Conftest <<module>> {
        +isolate_error_log() <<autouse fixture>>
    }
}

' Inheritance (cycle-12 modularization)
Calculator --|> BasicOperations : inherits (MRO 1)
Calculator --|> ScientificOperations : inherits (MRO 2)

' GUI mode hierarchy (cycle-15)
SimpleMode --|> CalculatorMode : extends
ScientificMode --|> CalculatorMode : extends

' Package re-exports
OpsInit ..> BasicOperations : re-exports
OpsInit ..> ScientificOperations : re-exports

' Runtime relationships
CalculatorSession --> Calculator : holds & delegates
Main --> CalculatorSession : instantiates & delegates
Main --> ErrLog : calls log_error
CLI --> CalculatorSession : instantiates & delegates
CLI --> ErrLog : calls log_error
Init ..> Calculator : re-exports
Init ..> CalculatorSession : re-exports

' GUI runtime relationships (cycles 15-16)
CalculatorGUI --> CalculatorSession : holds & delegates
CalculatorGUI --> CalculatorMode : uses (polymorphic)
CalculatorGUI --> _OperandSection : owns
CalculatorGUI --> ErrLog : calls log_error("gui", ...)
GUIModule ..> CalculatorGUI : instantiates & calls mainloop
GUIModule ..> CalculatorMode : re-exports
GUIModule ..> SimpleMode : re-exports
GUIModule ..> ScientificMode : re-exports
GUILauncher ..> GUIModule : delegates to src.gui.main()

' Test relationships
TestCalc --> Calculator : tests via fixture
TestSession --> CalculatorSession : tests via fixture
TestMain --> Main : tests via mocked stdin/stdout
TestCLI --> CLI : tests via capsys
TestErrLog --> ErrLog : tests via fixture
TestGUI --> CalculatorMode : tests directly
TestGUI ..> ParseNumber : tests parse_number
Conftest ..> ErrLog : patches ERROR_LOG_FILE

note right of Calculator
  Cycle-12 modularization: Calculator adds no methods.
  MRO: Calculator → BasicOperations → ScientificOperations → object.
  All 18 operations come from the two mixin classes.
  Public API is identical to the pre-modularization class;
  no callers (session, CLIs, tests) required updating.
end note

note right of BasicOperations
  Four standard arithmetic operations.
  No math import; uses Python built-in operators only.
  divide: ZeroDivisionError comes from Python "/" runtime —
  no explicit zero guard in the method body.
end note

note right of ScientificOperations
  14 advanced operations.  Imports math.
  factorial: guards bool before int (bool is int subclass);
    raises TypeError for non-int/bool, ValueError for negatives.
  square_root: raises ValueError for x < 0.
  cube_root: handles negatives via -(abs(x)^(1/3)).
  log: base-10 via math.log10; raises ValueError for x <= 0.
  ln: natural log via math.log; raises ValueError for x <= 0.
  power: base ** exp (no domain restriction).
  Trig (all accept/return degrees; math.radians/degrees for conversion):
    sin, cos: no domain restriction.
    tan: raises ValueError when cos(x) ≈ 0 (odd multiples of 90°).
    cot: raises ValueError when sin(x) ≈ 0 (multiples of 180°).
    asin, acos: raise ValueError for |x| > 1.
  Domain guards use abs(val) < 1e-10 threshold for near-zero.
end note

note left of Main
  Two operation maps (cycle-14, issue-281):
    NORMAL_OPERATIONS: keys "1"-"6"
      add(1), subtract(2), multiply(3), divide(4),
      square(5), square_root(6)
    SCIENTIFIC_OPERATIONS: keys "1"-"18"
      same as Normal plus:
      factorial(7), cube(8), cube_root(9), power(10),
      log(11), ln(12), sin(13), cos(14), tan(15),
      cot(16), asin(17), acos(18)
  Mode switch: 'm' prompts mode selection (1=Normal, 2=Scientific).
    Unknown mode choice retains current mode.
    Mode switch does NOT reset session history.
  MAX_ATTEMPTS=5: max failed input attempts before session terminates.
  HISTORY_FILE="history.txt": path for session history.
  get_number: parses as int first, then float;
    require_int=True forces strict integer (factorial).
  get_number_with_retry: wraps get_number; prints remaining-attempts
    message on each failure; raises _SessionExpired after MAX_ATTEMPTS.
  format_history_entry: delegates to CalculatorSession.format_entry.
  save_history: overwrites HISTORY_FILE with history list;
    called on all exit paths (quit, expiry, max-attempts).
  main: creates CalculatorSession; 'h' displays history;
    'm' triggers mode selection; computation dispatched via
    session.execute(); catches ValueError/TypeError/ZeroDivisionError
    per iteration; tracks invalid op selections (terminate after
    MAX_ATTEMPTS); catches _SessionExpired.
end note

note right of CalculatorSession
  BINARY_OPS: {add, subtract, multiply, divide, power} — 5 ops.
  UNARY_OPS: {factorial, square, cube, square_root, cube_root,
              log, ln, sin, cos, tan, cot, asin, acos} — 13 ops.
  ALL_OPS: BINARY_OPS | UNARY_OPS (18 operations total).
  Both CLIs import BINARY_OPS/ALL_OPS from here —
  single source of truth for operation arity metadata.
  execute(): dispatches via getattr(_calc, name)(*args);
    failed calls (any exception) do NOT append to history.
  format_entry(): static; "name(arg1, arg2) = result".
  history(): returns a defensive copy.
  save(): writes history to file (overwrites).
end note

note right of CLI
  Non-interactive bash CLI: one invocation, one result.
  Exit code 0 on success, 1 on any error.
  Imports BINARY_OPS, ALL_OPS from src.session
  (no local copies — single source of truth).
  _parse_operand: int first, then float;
    require_int=True for factorial.
  Errors go to stderr; result goes to stdout.
end note

note right of CalculatorGUI
  Cycle-16 (issue-303): ttk-based redesign.
  Six sections (top→bottom): Mode, Operation, Operands,
  Actions (Calculate + Clear), Result, Session History.
  Mode radio buttons: Simple (6 ops) / Scientific (18 ops).
  Operation combobox: display labels from CalculatorMode.operations.
  Arity badge: "Unary" or "Binary" next to combobox.
  _OperandSection: shows/hides second operand row via set_arity().
  Factorial input uses int() to preserve factorial's integer contract.
  Errors displayed in result label; forwarded to log_error("gui", ...).
  Session history persists across mode switches.
  Requires tkinter display — not importable in headless CI.
end note

note right of CalculatorMode
  Cycle-15 (issue-284): mode abstraction layer.
  SimpleMode.name = "Simple"; 6 operations.
  ScientificMode.name = "Scientific"; 18 operations.
  ScientificMode.operations ⊃ SimpleMode.operations (strict superset).
  All op names are members of BINARY_OPS | UNARY_OPS.
  operations property returns a fresh dict each call
  (no shared mutable state between callers).
  parse_number: int first, then float; ValueError for invalid input.
  No tkinter import — fully testable without a display.
end note

@enduml
