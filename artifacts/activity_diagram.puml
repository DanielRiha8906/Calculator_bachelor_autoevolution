@startuml activity_diagram

skinparam activity {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
    DiamondBackgroundColor White
    DiamondBorderColor Black
}

start

:Instantiate Calculator;

:calc.add(a, b);
:Return a + b;

:calc.subtract(a, b);
:Return a - b;

:calc.multiply(a, b);
:Return a * b;

:Call calc.divide(a, b);
if (b == 0?) then (yes)
    :Raise ValueError\n"Division by zero is not allowed";
    stop
else (no)
    :Return a / b;
endif

:Call calc.factorial(n);
if (n is not int?) then (yes)
    :Raise ValueError\n"Factorial only defined for\nnon-negative integers";
    stop
else (no)
    if (n < 0?) then (yes)
        :Raise ValueError\n"Factorial not defined\nfor negative integers";
        stop
    else (no)
        :Return math.factorial(n);
    endif
endif

:calc.square(a);
:Return a ** 2;

:calc.cube(a);
:Return a ** 3;

:Call calc.square_root(a);
if (a < 0?) then (yes)
    :Raise ValueError\n"Square root not defined\nfor negative numbers";
    stop
else (no)
    :Return math.sqrt(a);
endif

:Call calc.cube_root(a);
if (a < 0?) then (yes)
    :Return -((-a) ** (1/3))\n(sign-preserving real root);
else (no)
    :Return a ** (1/3);
endif

:calc.power(a, b);
:Return a ** b;

:Call calc.log(a, base);
if (a <= 0?) then (yes)
    :Raise ValueError\n"a must be positive";
    stop
else (no)
    if (base <= 0 or base == 1?) then (yes)
        :Raise ValueError\n"Invalid base";
        stop
    else (no)
        :Return math.log(a, base);
    endif
endif

:Call calc.ln(a);
if (a <= 0?) then (yes)
    :Raise ValueError\n"a must be positive";
    stop
else (no)
    :Return math.log(a);
endif

stop

@enduml
