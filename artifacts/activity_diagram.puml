@startuml activity_diagram

title Calculator — Activity Diagram

' ── Bash CLI flow ──────────────────────────────────────────────────────────

partition "Bash CLI (main.py → CLIHandler)" {

    start

    :Receive argv from command line;
    :setup_error_logging() → attach FileHandler to error.log;
    :Instantiate CLIHandler();
    :CLIHandler.run(argv);

    if (argv is empty?) then (yes)
        :logger.error("[cli] missing required operation argument");
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :operation = argv[0];

    if (operation not in CLI_OPERATIONS?) then (yes)
        :logger.error("[cli] unknown operation: <op>");
        :Print "Error: unknown operation" to stderr;
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :Look up (method_name, arity) from CLI_OPERATIONS;

    if (len(argv) != arity + 1?) then (yes)
        :logger.error("[cli] incorrect argument count for '...'");
        :Print "Error: requires N operand(s)" to stderr;
        :Exit with code 1;
        stop
    endif

    :Parse operand strings via _parse_operand()\n(require_int=True for factorial);

    if (ValueError during parsing?) then (yes)
        :logger.error("[cli] invalid operand for '...': <exc>");
        :Print "Error: <message>" to stderr;
        :Exit with code 1;
        stop
    endif

    :Resolve method via getattr(_calc, method_name);
    :result = method(*operands);

    if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
        :logger.error("[cli] calculation error in <op>: <exc>");
        :Print "Error: <exception message>" to stderr;
        :Exit with code 1;
        stop
    else (no)
        :Print result to stdout;
        stop
    endif

}

' ── Interactive session flow ────────────────────────────────────────────────

partition "Interactive Session (src/__main__.py → InteractiveSession)" {

    start

    :Instantiate InteractiveSession();
    :InteractiveSession.run();
    :setup_error_logging() → attach FileHandler to error.log;
    :Print "=== Interactive Calculator ===";
    :_history = [];
    :_menu_failures = 0;

    repeat

        :_display_menu() — print options 1–12, h, q;
        :Read user choice from stdin;

        if (choice == 'q'?) then (yes)
            :_write_history(_history) → history.txt;
            :Print "Goodbye!";
            stop
        elseif (choice == 'h'?) then (yes)
            if (_history is empty?) then (yes)
                :Print "No calculations yet.";
            else (no)
                :_show_history() — print each entry;
            endif
        elseif (choice not in OPERATIONS?) then (yes)
            :_menu_failures += 1;
            :logger.error("[interactive] invalid menu choice: <choice>");
            :Print "Invalid choice" error\n+ list of available options;
            if (_menu_failures >= MAX_RETRIES?) then (yes)
                :logger.error("[interactive] max retries exceeded for menu selection");
                :Print "Too many invalid selections.\nEnding session.";
                :_write_history(_history) → history.txt;
                stop
            else (no)
                :Print remaining attempts;
            endif
        else (valid choice)
            :_menu_failures = 0;
            :_handle_operation(choice);
            :Look up (op_name, label, arity) from OPERATIONS;
            :Resolve method via getattr(_calc, op_name);

            if (arity == 1?) then (yes)
                :_prompt_number("Enter value:", require_int)\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :a = parsed value;
                :result = method(a);
            else (arity == 2)
                :_prompt_number("Enter first value:")\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :a = parsed value;
                :_prompt_number("Enter second value:")\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :b = parsed value;
                :result = method(a, b);
            endif

            if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
                :logger.error("[interactive] calculation error in <op>: <exc>");
                :Print "Error: <exception message>";
            else (no)
                :Print "Result: <result>";
                :_history.append(_format_history_entry(op_name, operands, result));
            endif
        endif

    repeat while (session continues)

}

@enduml
