@startuml activity_diagram

title Calculator — Activity Diagram

start

if (Command-line arguments provided?) then (yes)

  :Parse arguments with argparse\n(operation + operands);

  if (Parse error?) then (yes)
    :Print usage to stderr;
    stop
  endif

  :Instantiate Calculator;
  :_dispatch(calc, args);
  :Call Calculator method;

  if (ValueError or ZeroDivisionError raised?) then (yes)
    :Print "Error: <message>" to stderr;
    :Exit with code 1;
    stop
  else (no)
    :Print result to stdout;
    stop
  endif

else (no)

  :Display "Welcome to the Calculator!";
  :Instantiate Calculator;
  :consecutive_invalid_choices = 0;

  repeat

    :display_menu();
    :Read user choice;

    if (choice == "0"?) then (yes)
      :Print "Goodbye!";
      stop
    endif

    if (choice in 1–12?) then (no)
      :consecutive_invalid_choices += 1;
      :Print "Unknown operation";
      if (consecutive_invalid_choices >= MAX_INPUT_ATTEMPTS?) then (yes)
        :Print "Too many invalid choices.\nEnding session.";
        stop
      endif
    else (yes)
      :consecutive_invalid_choices = 0;
      :perform_operation(calc, choice);

      if (operand input valid?) then (no — retry up to MAX_INPUT_ATTEMPTS)
        :Print "Invalid input... N attempt(s) remaining";
        if (attempts exhausted?) then (yes)
          :Print "Maximum input attempts exceeded.";
          stop
        endif
      else (yes)
        :Call Calculator method;

        if (ValueError or ZeroDivisionError raised?) then (yes)
          :Print "Error: <message>";
        else (no)
          :Print "Result: <value>";
        endif
      endif
    endif

  repeat while (user has not exited)

endif

@enduml
