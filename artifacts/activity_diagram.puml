@startuml activity_diagram

skinparam ActivityFontSize 13
skinparam ArrowFontSize 12

title Calculator — Execution Flows

|Interactive CLI (src/__main__.py)|
|CalculatorSession (src/session.py)|
|Bash CLI (main.py)|
|Calculator Computation|

== Interactive Mode (python -m src) ==

|Interactive CLI (src/__main__.py)|

start

:Instantiate CalculatorSession;
note right: session wraps a private Calculator\ninstance and an empty history list
:display_menu() — print all 12 operations + "h. history" + "q. quit";
note right: invalid_op_attempts = 0

repeat

  :Read user choice from stdin;

  if (choice.lower() == 'q'?) then (yes)
    :save_history(session.history()) — write to HISTORY_FILE;
    :Print "Goodbye!";
    stop
  elseif (choice.lower() == 'h'?) then (yes)
    if (session.history() is empty?) then (yes)
      :Print "No history yet.";
    else (no)
      :Print "Session history:"\nthen each entry;
    endif
  elseif (choice not in OPERATIONS?) then (yes)
    :Increment invalid_op_attempts;
    :log_error("interactive", "unknown operation '...'");
    :Print unknown operation warning\nwith list of available operations;
    if (invalid_op_attempts >= MAX_ATTEMPTS?) then (yes)
      :save_history(session.history()) — write to HISTORY_FILE;
      :Print "Maximum attempts reached. Ending session.";
      stop
    endif
  else (no — valid key)
    :Look up (name, arity) from OPERATIONS;

    if (arity == 1?) then (yes)
      if (name == "factorial"?) then (yes)
        :get_number_with_retry(require_int=True)\nup to MAX_ATTEMPTS attempts\nbefore raising _SessionExpired;
      else (no)
        :get_number_with_retry()\nup to MAX_ATTEMPTS attempts\nbefore raising _SessionExpired;
      endif

      |CalculatorSession (src/session.py)|
      :session.execute(name, a)\n  → getattr(_calc, name)(a);

    else (no — arity == 2)
      |Interactive CLI (src/__main__.py)|
      :get_number_with_retry() → a\nup to MAX_ATTEMPTS attempts;
      :get_number_with_retry() → b\nup to MAX_ATTEMPTS attempts;

      |CalculatorSession (src/session.py)|
      :session.execute(name, a, b)\n  → getattr(_calc, name)(a, b);
    endif

    |Calculator Computation|
    if (Operation is add?) then (yes)
      :Compute a + b;
    elseif (Operation is subtract?) then (yes)
      :Compute a - b;
    elseif (Operation is multiply?) then (yes)
      :Compute a * b;
    elseif (Operation is divide?) then (yes)
      if (b == 0?) then (yes)
        :Python raises ZeroDivisionError;
      else (no)
        :Compute a / b;
      endif
    elseif (Operation is factorial?) then (yes)
      if (n is bool or not int?) then (yes)
        :Raise TypeError;
      elseif (n < 0?) then (yes)
        :Raise ValueError;
      else (no)
        :Compute n! iteratively\n(result=1; for i in 2..n: result*=i);
      endif
    elseif (Operation is square?) then (yes)
      :Compute x * x;
    elseif (Operation is cube?) then (yes)
      :Compute x * x * x;
    elseif (Operation is square_root?) then (yes)
      if (x < 0?) then (yes)
        :Raise ValueError\n(undefined in reals);
      else (no)
        :Compute math.sqrt(x);
      endif
    elseif (Operation is cube_root?) then (yes)
      if (x < 0?) then (yes)
        :Compute -(abs(x) ** (1/3))\n(real negative cube root);
      else (no)
        :Compute x ** (1/3);
      endif
    elseif (Operation is power?) then (yes)
      :Compute base ** exp;
    elseif (Operation is log?) then (yes)
      if (x <= 0?) then (yes)
        :Raise ValueError\n(log undefined for non-positive);
      else (no)
        :Compute math.log10(x);
      endif
    else (ln)
      if (x <= 0?) then (yes)
        :Raise ValueError\n(ln undefined for non-positive);
      else (no)
        :Compute math.log(x);
      endif
    endif

    |CalculatorSession (src/session.py)|
    if (exception raised?) then (yes)
      :Propagate exception to caller;
    else (no)
      :Append format_entry(name, args, result)\nto _history list;
      :Return result;
    endif

    |Interactive CLI (src/__main__.py)|
    if (_SessionExpired raised by operand input?) then (yes)
      :save_history(session.history()) — write to HISTORY_FILE;
      stop
    elseif (operation raised ValueError/TypeError/ZeroDivisionError?) then (yes)
      :log_error("interactive", "calculation error in <name>: ...");
      :Print "Error: <message>";
    else (no)
      :Print "Result: <value>";
    endif

  endif

repeat while (session continues)

== Bash CLI Mode (python main.py <op> [args]) ==

|Bash CLI (main.py)|

start

:Receive argv (sys.argv[1:]);

if (argv is empty?) then (yes)
  :log_error("cli", "no arguments provided");
  :Print usage to stderr;
  :Exit code 1;
  stop
endif

:operation = argv[0];

if (operation not in ALL_OPS?) then (yes)
  :log_error("cli", "unknown operation '...'");
  :Print "Error: unknown operation" to stderr;
  :Exit code 1;
  stop
endif

:Instantiate CalculatorSession;

if (operation in BINARY_OPS?) then (yes)
  if (len(argv) != 3?) then (yes)
    :log_error("cli", "requires two operands, got N");
    :Print "requires exactly two operands" to stderr;
    :Exit code 1;
    stop
  else (no — correct arg count)
    :_parse_operand(argv[1]) → a;
    :_parse_operand(argv[2]) → b;

    |CalculatorSession (src/session.py)|
    :session.execute(operation, a, b)\n  → getattr(_calc, operation)(a, b);
    |Calculator Computation|
    :Compute result (see operation branches above);
  endif
else (unary op)
  |Bash CLI (main.py)|
  if (len(argv) != 2?) then (yes)
    :log_error("cli", "requires one operand, got N");
    :Print "requires exactly one operand" to stderr;
    :Exit code 1;
    stop
  else (no — correct arg count)
    if (operation == "factorial"?) then (yes)
      :_parse_operand(argv[1], require_int=True) → a;
    else (no)
      :_parse_operand(argv[1]) → a;
    endif

    |CalculatorSession (src/session.py)|
    :session.execute(operation, a)\n  → getattr(_calc, operation)(a);
    |Calculator Computation|
    :Compute result (see operation branches above);
  endif
endif

|CalculatorSession (src/session.py)|
if (exception raised?) then (yes)
  :Propagate exception to caller;
else (no)
  :Append to history; return result;
endif

|Bash CLI (main.py)|
if (operation raised exception?) then (yes)
  :log_error("cli", "error in '<op>': ...");
  :Print "Error: <message>" to stderr;
  :Exit code 1;
  stop
else (no)
  :Print result to stdout;
  :Exit code 0;
  stop
endif

@enduml
