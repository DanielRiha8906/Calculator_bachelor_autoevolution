@startuml activity_diagram

title Calculator Entry — Activity Diagram

start

if (Command-line arguments provided?) then (yes)

    :Parse operation name from argv[1];

    if (Operation name is known?) then (no)
        :Print "Error: Unknown operation";
        :Print usage hint;
        :Exit with code 1;
        stop
    endif

    if (Operation requires 2 values?) then (yes)
        if (Exactly 2 values supplied?) then (no)
            :Print "Error: requires exactly 2 values";
            :Exit with code 1;
            stop
        endif
        :Parse argv[2] as float (_parse_float);
        if (Parse failed?) then (yes)
            :Print "Error: '<value>' is not a valid number";
            :Exit with code 1;
            stop
        endif
        :Parse argv[3] as float (_parse_float);
        if (Parse failed?) then (yes)
            :Print "Error: '<value>' is not a valid number";
            :Exit with code 1;
            stop
        endif
        :Call Calculator.<operation>(a, b);
    else (no)
        if (Exactly 1 value supplied?) then (no)
            :Print "Error: requires exactly 1 value";
            :Exit with code 1;
            stop
        endif
        :Parse argv[2] as float (_parse_float);
        if (Parse failed?) then (yes)
            :Print "Error: '<value>' is not a valid number";
            :Exit with code 1;
            stop
        endif
        if (Operation is factorial?) then (yes)
            :Validate input is a whole number;
            if (Not a whole number?) then (yes)
                :Raise ValueError;
            endif
            :Convert to int;
        endif
        :Call Calculator.<operation>(x);
    endif

    if (ValueError raised?) then (yes)
        :Print "Error: <message>";
        :Exit with code 1;
        stop
    else (no)
        :Print "Result: <value>";
        :Exit with code 0;
        stop
    endif

else (no)

    :Clear history file (history.txt);
    :Display operation menu (1-12, h, q);

    repeat

        :attempt = 0;

        repeat
            :Prompt user for operation choice;
            if (Input is 'q'?) then (yes)
                :Print "Goodbye!";
                stop
            endif
            if (Input is 'h'?) then (yes)
                :Display session history from file;
                note right: attempt not incremented
            elseif (Input is a valid number 1-12?) then (yes)
                :Select operation;
                break
            else (no)
                :attempt = attempt + 1;
                if (attempt < MAX_ATTEMPTS?) then (yes)
                    :Print "Invalid choice. Please try again.";
                else (no)
                    :Print "Too many invalid attempts. Ending session.";
                    stop
                endif
            endif
        repeat while (choice invalid or 'h')

        :attempt = 0;

        repeat
            if (Operation requires two operands?\n(add, subtract, multiply,\ndivide, power)) then (yes)
                :Prompt for operand a;
                :Prompt for operand b;
            else (no)
                :Prompt for single operand;
            endif

            if (Operation is factorial?) then (yes)
                :Validate input is a whole number;
            endif

            :Call Calculator.<operation>(operands);

            if (ValueError raised?) then (yes)
                :attempt = attempt + 1;
                :Print "Error: <message>";
                if (attempt < MAX_ATTEMPTS?) then (yes)
                    :Print "Please try again.";
                else (no)
                    :Print "Too many invalid inputs. Ending session.";
                    stop
                endif
            else (no)
                :Append "<op>(<operands>) = <result>" to history file;
                :Print "Result: <value>";
                break
            endif
        repeat while (input invalid)

        :Prompt "Continue? (y/n)";

    repeat while (User answers 'y'?) is (yes)
    ->no;

    :Print "Goodbye!";
    stop

endif

@enduml
