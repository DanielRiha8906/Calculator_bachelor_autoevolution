@startuml activity_diagram

skinparam activity {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
    DiamondBackgroundColor White
    DiamondBorderColor Black
}

start

:Instantiate Calculator;

:calc.add(10, 5);
:Print "Addition: 15";

:calc.subtract(10, 5);
:Print "Subtraction: 5";

:calc.multiply(10, 5);
:Print "Multiplication: 50";

:Call calc.divide(a, b);

if (b == 0?) then (yes)
    :Raise ValueError\n"Division by zero is not allowed";
    stop
else (no)
    :Return a / b;
    :Print "Division: <result>";
endif

:Call calc.factorial(n);

if (n is not int?) then (yes)
    :Raise ValueError\n"Factorial only defined for\nnon-negative integers";
    stop
else (no)
    if (n < 0?) then (yes)
        :Raise ValueError\n"Factorial not defined\nfor negative integers";
        stop
    else (no)
        :Return math.factorial(n);
        :Print "Factorial: <result>";
    endif
endif

stop

@enduml
