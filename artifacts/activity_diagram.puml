@startuml activity_diagram

skinparam ActivityFontSize 13
skinparam ArrowFontSize 12

title Calculator — Execution Flows

|Interactive CLI (src/__main__.py)|
|CalculatorSession (src/session.py)|
|Bash CLI (main.py)|
|GUI (src/gui.py)|
|Calculator Computation|

== Interactive Mode (python -m src) ==

|Interactive CLI (src/__main__.py)|

start

:Instantiate CalculatorSession;
note right: session wraps a private Calculator\ninstance and an empty history list
:current_mode = "Normal"\ncurrent_ops = NORMAL_OPERATIONS;
note right
  NORMAL_OPERATIONS: keys "1"-"6"
    add, subtract, multiply, divide, square, square_root
  SCIENTIFIC_OPERATIONS: keys "1"-"18"
    all Normal ops plus: factorial, cube, cube_root, power,
    log, ln, sin, cos, tan, cot, asin, acos
end note
:display_menu(current_ops, current_mode) — print mode name + ops + "m. switch mode" + "h. history" + "q. quit";
note right: invalid_op_attempts = 0

repeat

  :Read user choice from stdin;

  if (choice.lower() == 'q'?) then (yes)
    :save_history(session.history()) — write to HISTORY_FILE;
    :Print "Goodbye!";
    stop
  elseif (choice.lower() == 'h'?) then (yes)
    if (session.history() is empty?) then (yes)
      :Print "No history yet.";
    else (no)
      :Print "Session history:"\nthen each entry;
    endif
  elseif (choice.lower() == 'm'?) then (yes)
    :Print "Select mode: 1. Normal  2. Scientific";
    :Read mode_choice from stdin;
    if (mode_choice == "1"?) then (yes)
      :current_mode = "Normal"\ncurrent_ops = NORMAL_OPERATIONS;
    elseif (mode_choice == "2"?) then (yes)
      :current_mode = "Scientific"\ncurrent_ops = SCIENTIFIC_OPERATIONS;
    else (unknown)
      :Print "Unknown mode '...'. Keeping <current_mode> mode.";
    endif
    :display_menu(current_ops, current_mode);
  elseif (choice not in current_ops?) then (yes)
    :Increment invalid_op_attempts;
    :log_error("interactive", "unknown operation '...'");
    :Print unknown operation warning\nwith list of available operations;
    if (invalid_op_attempts >= MAX_ATTEMPTS?) then (yes)
      :save_history(session.history()) — write to HISTORY_FILE;
      :Print "Maximum attempts reached. Ending session.";
      stop
    endif
  else (no — valid key)
    :Look up (name, arity) from current_ops;

    if (arity == 1?) then (yes)
      if (name == "factorial"?) then (yes)
        :get_number_with_retry(require_int=True)\nup to MAX_ATTEMPTS attempts\nbefore raising _SessionExpired;
      else (no)
        :get_number_with_retry()\nup to MAX_ATTEMPTS attempts\nbefore raising _SessionExpired;
      endif

      |CalculatorSession (src/session.py)|
      :session.execute(name, a)\n  → getattr(_calc, name)(a);

    else (no — arity == 2)
      |Interactive CLI (src/__main__.py)|
      :get_number_with_retry() → a\nup to MAX_ATTEMPTS attempts;
      :get_number_with_retry() → b\nup to MAX_ATTEMPTS attempts;

      |CalculatorSession (src/session.py)|
      :session.execute(name, a, b)\n  → getattr(_calc, name)(a, b);
    endif

    |Calculator Computation|
    note right
      BasicOperations (src/operations/basic.py):
        add, subtract, multiply, divide
      ScientificOperations (src/operations/scientific.py):
        factorial, square, cube, square_root,
        cube_root, power, log, ln,
        sin, cos, tan, cot, asin, acos
      Calculator inherits both via MRO.
    end note
    if (Operation is add?) then (yes)
      :Compute a + b;
    elseif (Operation is subtract?) then (yes)
      :Compute a - b;
    elseif (Operation is multiply?) then (yes)
      :Compute a * b;
    elseif (Operation is divide?) then (yes)
      if (b == 0?) then (yes)
        :Python raises ZeroDivisionError;
      else (no)
        :Compute a / b;
      endif
    elseif (Operation is factorial?) then (yes)
      if (n is bool or not int?) then (yes)
        :Raise TypeError;
      elseif (n < 0?) then (yes)
        :Raise ValueError;
      else (no)
        :Compute n! iteratively\n(result=1; for i in 2..n: result*=i);
      endif
    elseif (Operation is square?) then (yes)
      :Compute x * x;
    elseif (Operation is cube?) then (yes)
      :Compute x * x * x;
    elseif (Operation is square_root?) then (yes)
      if (x < 0?) then (yes)
        :Raise ValueError\n(undefined in reals);
      else (no)
        :Compute math.sqrt(x);
      endif
    elseif (Operation is cube_root?) then (yes)
      if (x < 0?) then (yes)
        :Compute -(abs(x) ** (1/3))\n(real negative cube root);
      else (no)
        :Compute x ** (1/3);
      endif
    elseif (Operation is power?) then (yes)
      :Compute base ** exp;
    elseif (Operation is log?) then (yes)
      if (x <= 0?) then (yes)
        :Raise ValueError\n(log undefined for non-positive);
      else (no)
        :Compute math.log10(x);
      endif
    elseif (Operation is ln?) then (yes)
      if (x <= 0?) then (yes)
        :Raise ValueError\n(ln undefined for non-positive);
      else (no)
        :Compute math.log(x);
      endif
    elseif (Operation is sin?) then (yes)
      :Compute math.sin(math.radians(x));
    elseif (Operation is cos?) then (yes)
      :Compute math.cos(math.radians(x));
    elseif (Operation is tan?) then (yes)
      if (abs(cos(x)) < 1e-10?) then (yes)
        :Raise ValueError\n(tan undefined where cos(x) = 0);
      else (no)
        :Compute math.tan(math.radians(x));
      endif
    elseif (Operation is cot?) then (yes)
      if (abs(sin(x)) < 1e-10?) then (yes)
        :Raise ValueError\n(cot undefined where sin(x) = 0);
      else (no)
        :Compute cos(x) / sin(x);
      endif
    elseif (Operation is asin?) then (yes)
      if (|x| > 1?) then (yes)
        :Raise ValueError\n(asin undefined for |x| > 1);
      else (no)
        :Compute math.degrees(math.asin(x));
      endif
    else (acos)
      if (|x| > 1?) then (yes)
        :Raise ValueError\n(acos undefined for |x| > 1);
      else (no)
        :Compute math.degrees(math.acos(x));
      endif
    endif

    |CalculatorSession (src/session.py)|
    if (exception raised?) then (yes)
      :Propagate exception to caller;
    else (no)
      :Append format_entry(name, args, result)\nto _history list;
      :Return result;
    endif

    |Interactive CLI (src/__main__.py)|
    if (_SessionExpired raised by operand input?) then (yes)
      :save_history(session.history()) — write to HISTORY_FILE;
      stop
    elseif (operation raised ValueError/TypeError/ZeroDivisionError?) then (yes)
      :log_error("interactive", "calculation error in <name>: ...");
      :Print "Error: <message>";
    else (no)
      :Print "Result: <value>";
    endif

  endif

repeat while (session continues)

== Bash CLI Mode (python main.py <op> [args]) ==

|Bash CLI (main.py)|

start

:Receive argv (sys.argv[1:]);

if (argv is empty?) then (yes)
  :log_error("cli", "no arguments provided");
  :Print usage to stderr;
  :Exit code 1;
  stop
endif

:operation = argv[0];

if (operation not in ALL_OPS?) then (yes)
  :log_error("cli", "unknown operation '...'");
  :Print "Error: unknown operation" to stderr;
  :Exit code 1;
  stop
endif

:Instantiate CalculatorSession;

if (operation in BINARY_OPS?) then (yes)
  if (len(argv) != 3?) then (yes)
    :log_error("cli", "requires two operands, got N");
    :Print "requires exactly two operands" to stderr;
    :Exit code 1;
    stop
  else (no — correct arg count)
    :_parse_operand(argv[1]) → a;
    :_parse_operand(argv[2]) → b;

    |CalculatorSession (src/session.py)|
    :session.execute(operation, a, b)\n  → getattr(_calc, operation)(a, b);
    |Calculator Computation|
    :Compute result (see operation branches above);
  endif
else (unary op)
  |Bash CLI (main.py)|
  if (len(argv) != 2?) then (yes)
    :log_error("cli", "requires one operand, got N");
    :Print "requires exactly one operand" to stderr;
    :Exit code 1;
    stop
  else (no — correct arg count)
    if (operation == "factorial"?) then (yes)
      :_parse_operand(argv[1], require_int=True) → a;
    else (no)
      :_parse_operand(argv[1]) → a;
    endif

    |CalculatorSession (src/session.py)|
    :session.execute(operation, a)\n  → getattr(_calc, operation)(a);
    |Calculator Computation|
    :Compute result (see operation branches above);
  endif
endif

|CalculatorSession (src/session.py)|
if (exception raised?) then (yes)
  :Propagate exception to caller;
else (no)
  :Append to history; return result;
endif

|Bash CLI (main.py)|
if (operation raised exception?) then (yes)
  :log_error("cli", "error in '<op>': ...");
  :Print "Error: <message>" to stderr;
  :Exit code 1;
  stop
else (no)
  :Print result to stdout;
  :Exit code 0;
  stop
endif

== GUI Mode (python gui_main.py) ==

|GUI (src/gui.py)|

start

:python gui_main.py → src.gui.main()\ncreate tk.Tk() root, CalculatorGUI(root), root.mainloop();
note right
  CalculatorGUI.__init__:
    - creates CalculatorSession (private _session)
    - builds 6 labelled sections:
        1. Mode (Normal/Scientific radio buttons)
        2. Operation (Binary/Unary radios + combobox)
        3. Operands (A always; B shown for binary only)
        4. Buttons (Calculate, Clear)
        5. Result (large-font label)
        6. Session History (scrollable text area)
    - initial state: Normal mode, Binary type, "add" selected
    - binds <Return> key → _on_calculate()
    - calls _on_arity_change() to set initial Operand B visibility
end note

repeat

  if (User selects Normal/Scientific mode radio?) then (yes)
    :_on_mode_change()\n→ op_section.refresh_for_mode()\n→ rebuild combobox values for new mode\n→ _on_arity_change() to update Operand B;
    note right
      Normal Binary:   [add, subtract, multiply, divide]
      Normal Unary:    [square, square_root]
      Scientific Binary: [add, subtract, multiply, divide, power]
      Scientific Unary:  [square, square_root, factorial, cube,
                           cube_root, log, ln, sin, cos, tan,
                           cot, asin, acos]
      Mode switch does NOT reset session history.
    end note
  elseif (User changes op type (Binary/Unary) or op name?) then (yes)
    :_on_arity_change()\n→ operand_section.set_binary_mode(is_binary, op_name)\n→ show Operand B if binary; hide if unary;
    note right
      factorial: Operand A label shows "(integer)" hint.
      Other unary: plain "Operand A:" label.
    end note
  elseif (User clicks Calculate or presses Enter?) then (yes)
    :_on_calculate(): read op_name from _op_name_var;

    if (op_name is empty?) then (yes)
      :result_section.show_error("No operation selected.");
    else (no)
      :operand_section.get_operands(op_name)\n  int(raw_a) for factorial\n  _parse_number(raw_a) for all other ops\n  adds b = _parse_number(raw_b) if op_name in BINARY_OPS;

      if (ValueError from operand parsing?) then (yes)
        :log_error("gui", f"calculation error in {op_name}: {exc}");
        :result_section.show_error(str(exc));
      else (no)
        |CalculatorSession (src/session.py)|
        :session.execute(op_name, *operands)\n  → getattr(_calc, op_name)(*operands);

        |Calculator Computation|
        :Compute result\n(same 18-operation branches as Interactive/Bash CLI sections);

        |CalculatorSession (src/session.py)|
        if (exception raised?) then (yes)
          :Propagate exception to CalculatorGUI;
        else (no)
          :Append format_entry to _history; return result;
        endif

        |GUI (src/gui.py)|
        if (ValueError / TypeError / ZeroDivisionError?) then (yes)
          :log_error("gui", f"calculation error in {op_name}: {exc}");
          :result_section.show_error(str(exc));
          note right: error shown in red; history NOT updated
        else (no)
          :result_section.show_result(result);
          :history_section.refresh(session.history());
        endif
      endif
    endif
  elseif (User clicks Clear?) then (yes)
    :_on_clear():\n  operand_a_var.set("")\n  operand_b_var.set("")\n  result_section.clear();
    note right: session history is NOT cleared by Clear
  else (User closes window)
    stop
  endif

repeat while (window open)

@enduml
