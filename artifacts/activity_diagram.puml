@startuml activity_diagram

title Calculator — Interactive REPL Flow

start

:Instantiate Calculator();
:Print "Welcome to the Calculator!";

repeat

  :Print MENU (12 operations + quit);
  :Read user choice via input();

  if (choice == "q"?) then (yes)
    :Print "Goodbye!";
    stop
  else (no)
  endif

  :Look up op = MENU_MAP.get(choice);

  if (op is None?) then (yes)
    :Print "Unknown choice" error message;
  else (no)

    if (op in BINARY_OPS?) then (yes)
      :parse_number() → a (first operand);
      :parse_number() → b (second operand);
    else (no — UNARY_OPS)
      :parse_number() → a;
      if (op in INTEGER_OPS?) then (yes)
        if (a is whole number?) then (yes)
          :Convert a float → int;
        else (no)
          :Raise ValueError\n"requires whole number";
        endif
      endif
    endif

    :Dispatch: getattr(calc, op)(args);

    if (ValueError or ZeroDivisionError raised?) then (yes)
      :Print "Error: <exception message>";
    else (no)
      :Print "Result: <value>";
    endif

  endif

repeat while (loop continues)

stop

@enduml
