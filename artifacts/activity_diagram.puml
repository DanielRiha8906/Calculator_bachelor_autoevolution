@startuml activity_diagram

start

:Invoke \`python -m src\`;

:Import Calculator from src;

:Instantiate Calculator;

:Call calc.add(10, 5);
:Print "Addition: 15";

:Call calc.subtract(10, 5);
:Print "Subtraction: 5";

:Call calc.multiply(10, 5);
:Print "Multiplication: 50";

:Call calc.divide(10, 5);

if (divisor == 0?) then (yes)
    :Raise ZeroDivisionError;
    stop
else (no)
    :Return quotient;
    :Print "Division: 2.0";
endif

:Call calc.factorial(5);

if (n < 0 or not integer?) then (yes)
    :Raise ValueError or TypeError;
    stop
else (no)
    :Return n!;
    :Print "Factorial: 120";
endif

stop

@enduml
