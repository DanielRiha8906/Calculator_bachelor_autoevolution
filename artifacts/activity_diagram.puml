@startuml activity_diagram

title Calculator — Activity Diagram

' ── Bash CLI flow ──────────────────────────────────────────────────────────

partition "Bash CLI (main.py)" {

    start

    :Receive argv from command line;

    if (argv is empty?) then (yes)
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :operation = argv[0];

    if (operation not in CLI_OPERATIONS?) then (yes)
        :Print "Error: unknown operation" to stderr;
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :Look up (method_name, arity) from CLI_OPERATIONS;

    if (len(argv) != arity + 1?) then (yes)
        :Print "Error: requires N operand(s)" to stderr;
        :Exit with code 1;
        stop
    endif

    :Parse operand strings via _parse_operand()\n(require_int=True for factorial);

    if (ValueError during parsing?) then (yes)
        :Print "Error: <message>" to stderr;
        :Exit with code 1;
        stop
    endif

    :Instantiate Calculator();
    :Resolve method via getattr(calc, method_name);
    :result = method(*operands);

    if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
        :Print "Error: <exception message>" to stderr;
        :Exit with code 1;
        stop
    else (no)
        :Print result to stdout;
        stop
    endif

}

' ── Interactive session flow ────────────────────────────────────────────────

partition "Interactive Session (src/__main__.py)" {

    start

    :Import Calculator from src;
    :Instantiate Calculator();
    :Print "=== Interactive Calculator ===";
    :menu_failures = 0;

    repeat

        :Display operation menu (options 1–12 and 'q');
        :Read user choice from stdin;

        if (choice == 'q'?) then (yes)
            :Print "Goodbye!";
            stop
        elseif (choice not in OPERATIONS?) then (yes)
            :menu_failures += 1;
            :Print "Invalid choice" error\n+ list of available options;
            if (menu_failures >= MAX_RETRIES?) then (yes)
                :Print "Too many invalid selections.\nEnding session.";
                stop
            else (no)
                :Print remaining attempts;
            endif
        else (valid choice)
            :menu_failures = 0;
            :Look up (op_name, label, arity) from OPERATIONS;
            :Resolve method via getattr(calc, op_name);

            if (arity == 1?) then (yes)
                :_prompt_number("Enter value:", require_int)\n[retries up to MAX_RETRIES on bad input];
                if (None returned — retries exhausted?) then (yes)
                    :Print "Too many invalid inputs.\nEnding session.";
                    stop
                endif
                :a = parsed value;
                :result = method(a);
            else (arity == 2)
                :_prompt_number("Enter first value:")\n[retries up to MAX_RETRIES on bad input];
                if (None returned — retries exhausted?) then (yes)
                    :Print "Too many invalid inputs.\nEnding session.";
                    stop
                endif
                :a = parsed value;
                :_prompt_number("Enter second value:")\n[retries up to MAX_RETRIES on bad input];
                if (None returned — retries exhausted?) then (yes)
                    :Print "Too many invalid inputs.\nEnding session.";
                    stop
                endif
                :b = parsed value;
                :result = method(a, b);
            endif

            if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
                :Print "Error: <exception message>";
            else (no)
                :Print "Result: <result>";
            endif
        endif

    repeat while (session continues)

}

@enduml
