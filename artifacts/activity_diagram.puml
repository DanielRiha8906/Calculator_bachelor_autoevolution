@startuml activity_diagram

skinparam activity {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
    DiamondBackgroundColor White
    DiamondBorderColor Black
}

note
  Module structure (cycle 11):
  main() lives in src.__main__
  cli_mode() lives in src.interface.cli
  run_operation / parse_number / parse_int /
    show_menu live in src.interface.interactive
  History helpers live in src.interface.history
  Calculator delegates to src.operations.basic
    and src.operations.scientific
end note

start

:args = sys.argv[1:] (or passed directly to main());

if (args non-empty?) then (yes)

    partition "cli_mode(args)" {
        :Parse args via argparse\n(operation + values);

        if (operation in _INT_ARG_OPS\n{factorial}?) then (yes)
            if (len(values) != 1?) then (yes)
                :append_to_error_log("invalid_input: ...")\nstderr: "Error: requires 1 integer argument";
                stop
            else (no)
                if (values[0] is not a valid integer?) then (yes)
                    :append_to_error_log("invalid_input: ...")\nstderr: "Error: '<value>' is not a valid integer";
                    stop
                else (no)
                    :n = int(values[0]);
                    :result = calc.execute(op, n);
                endif
            endif
        elseif (operation in _ONE_ARG_OPS\n{square, cube, square_root, cube_root, ln}?) then (yes)
            if (len(values) != 1?) then (yes)
                :append_to_error_log("invalid_input: ...")\nstderr: "Error: requires 1 argument";
                stop
            else (no)
                if (values[0] is not a valid number?) then (yes)
                    :append_to_error_log("invalid_input: ...")\nstderr: "Error: '<value>' is not a valid number";
                    stop
                else (no)
                    :a = float(values[0]);
                    :result = calc.execute(op, a);
                endif
            endif
        else (two-arg op\nadd / subtract / multiply\ndivide / power / log)
            if (len(values) != 2?) then (yes)
                :append_to_error_log("invalid_input: ...")\nstderr: "Error: requires 2 arguments";
                stop
            else (no)
                if (any value is not a valid number?) then (yes)
                    :append_to_error_log("invalid_input: ...")\nstderr: "Error: '<value>' is not a valid number";
                    stop
                else (no)
                    :a = float(values[0])\nb = float(values[1]);
                    :result = calc.execute(op, a, b);
                endif
            endif
        endif

        if (ValueError raised from Calculator?) then (yes)
            :append_to_error_log("calculation_error: ...")\nstderr: "Error: <message>"; exit(1);
        else (no)
            :stdout: print result; exit(0);
        endif
    }

else (no — interactive mode)

    :Instantiate Calculator\nclear_history()\ninvalid_op_count = 0;

    repeat

        :show_menu()\nPrint numbered operation menu (1-12),\n"h. show history", and "q. quit";
        :choice = input("Select operation:").strip().lower();

        if (choice == "q"?) then (yes)
            :Print "Goodbye!";
            stop
        elseif (choice == "h"?) then (yes)
            :show_history()\nPrint all entries from history file;
        elseif (choice not in OPERATIONS?) then (yes)
            :append_to_error_log("invalid_input: ...")\ninvalid_op_count += 1;
            if (invalid_op_count >= MAX_ATTEMPTS?) then (yes)
                :Print "Invalid choice. Too many invalid choices. Ending session.";
                stop
            else (no)
                :Print "Invalid choice: '<choice>'. <remaining> attempt(s) left.";
            endif
        else (valid choice)
            :invalid_op_count = 0;
            :operation = OPERATIONS[choice];

            partition "run_operation(calc, operation)" {

                if (operation == "factorial"?) then (yes)
                    :parse_int("Enter non-negative integer:")\nnote: each invalid try → append_to_error_log;\n      up to MAX_ATTEMPTS=3 tries;\nraises TooManyAttemptsError on exhaustion;
                elseif (two-argument operation?\nadd / subtract / multiply\ndivide / power / log) then (yes)
                    :parse_number("Enter first/dividend/base number:")\nnote: each invalid try → append_to_error_log;\n      up to MAX_ATTEMPTS=3 tries;\nraises TooManyAttemptsError on exhaustion;
                    :parse_number("Enter second/divisor/exponent/base:")\nnote: each invalid try → append_to_error_log;\n      up to MAX_ATTEMPTS=3 tries;\nraises TooManyAttemptsError on exhaustion;
                else (one-argument operation\nsquare / cube / square_root\ncube_root / ln)
                    :parse_number("Enter number:")\nnote: each invalid try → append_to_error_log;\n      up to MAX_ATTEMPTS=3 tries;\nraises TooManyAttemptsError on exhaustion;
                endif

                :calc.execute(operation, *args)\n→ dispatches to named Calculator method via getattr;

                if (ValueError raised?\ne.g. divide-by-zero, negative sqrt,\nnegative factorial, invalid log base) then (yes)
                    :append_to_error_log("calculation_error: ...")\nPrint "Error: <message>"\nreturn None;
                else (no)
                    :Print "Result: <value>"\nreturn "op(args) = result" entry string;
                endif

            }

            if (TooManyAttemptsError propagated from parse?) then (yes)
                :Print "Too many invalid inputs. Ending session.";
                stop
            elseif (entry != None?) then (yes)
                :append_to_history(entry)\nWrite entry line to history file;
            endif
        endif

    repeat while (loop continues)

endif

@enduml
