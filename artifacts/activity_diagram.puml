@startuml activity_diagram

title Calculator — Activity Diagram

start

if (--gui flag in arguments?) then (yes)

  :Create tk.Tk root window;
  :Instantiate CalculatorGUI(root)\n— clears history, builds UI;
  :root.mainloop() — enter tkinter event loop;

  fork
    :User clicks an operation button;
    :_select_operation(op)\n— update UI fields shown/hidden;
  fork again
    :User clicks Calculate\n(or presses Enter);
    :_calculate();

    :parse_operand(entry_a)\n[integer if factorial];
    if (parse error?) then (yes)
      :messagebox.showerror("Input Error");
    else (no)
      if (binary operation?) then (yes)
        :parse_operand(entry_b);
        if (parse error?) then (yes)
          :messagebox.showerror("Input Error");
        endif
      endif
      if (log operation?) then (yes)
        :parse_operand(entry_base, default=10);
        if (parse error?) then (yes)
          :messagebox.showerror("Input Error");
        endif
      endif
      :controller.execute(op, a, b, base)\n→ Calculator facade\n→ operations module function;
      if (ValueError or ZeroDivisionError raised?) then (yes)
        :log_error("[gui] <operation>: <message>");
        :messagebox.showerror("Calculation Error");
      else (no)
        :result_label.config(text=result);
        :record_entry(label + ": " + result);
      endif
    endif
  fork again
    :User clicks Switch Mode button;
    :_toggle_mode()\n— show/hide scientific buttons\n— deselect op if now unavailable;
  fork again
    :User clicks Show History;
    :_show_history()\n— load_history()\n— display Toplevel popup;
  end fork

  :User closes the window;
  stop

elseif (Other command-line arguments provided?) then (yes)

  :Parse arguments with argparse\n(operation + operands);

  if (Parse error?) then (yes)
    :Print usage to stderr;
    stop
  endif

  :Instantiate CalculatorController;
  :_dispatch(controller, args);
  :controller.execute() → Calculator method\n→ operations module function;

  if (ValueError or ZeroDivisionError raised?) then (yes)
    :log_error("[cli] <operation>: <message>");
    :Print "Error: <message>" to stderr;
    :Exit with code 1;
    stop
  else (no)
    :Print result to stdout;
    stop
  endif

else (no arguments — interactive mode)

  :Display "Welcome to the Calculator!";
  :Instantiate CalculatorController;
  :clear_history() — wipe history.txt;
  :mode = "normal"\nconsecutive_invalid_choices = 0\nvalid_choices = NORMAL_VALID_CHOICES;

  repeat

    :display_menu(mode);
    :Read user choice;

    if (choice == "0"?) then (yes)
      :Print "Goodbye!";
      stop
    endif

    if (choice in valid_choices?) then (no)
      :consecutive_invalid_choices += 1;
      :log_error("[interactive] Unknown operation choice");
      :Print "Unknown operation";
      if (consecutive_invalid_choices >= MAX_INPUT_ATTEMPTS?) then (yes)
        :Print "Too many invalid choices.\nEnding session.";
        stop
      endif
    else (yes)
      :consecutive_invalid_choices = 0;

      if (choice == "13"?) then (yes)
        :display_history();
      elseif (choice == "14"?) then (yes)
        if (mode == "normal"?) then (yes)
          :mode = "scientific"\nvalid_choices = SCIENTIFIC_VALID_CHOICES;
          :Print "Switched to Scientific Mode.";
        else (no)
          :mode = "normal"\nvalid_choices = NORMAL_VALID_CHOICES;
          :Print "Switched to Normal Mode.";
        endif
      else (no — choice 1–12)
        :perform_operation(controller, choice);

        if (operand input valid?) then (no — retry up to MAX_INPUT_ATTEMPTS)
          :Print "Invalid input... N attempt(s) remaining";
          if (attempts exhausted?) then (yes)
            :Print "Maximum input attempts exceeded.";
            stop
          endif
        else (yes)
          :controller.execute() → Calculator facade\n→ operations module function\n(arithmetic / algebraic / transcendental);

          if (ValueError or ZeroDivisionError raised?) then (yes)
            :log_error("[interactive] <operation>: <message>");
            :Print "Error: <message>";
          else (no)
            :record_entry(operation + result)\nto history.txt;
            :Print "Result: <value>";
          endif
        endif
      endif
    endif

  repeat while (user has not exited)

endif

@enduml
