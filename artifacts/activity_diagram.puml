@startuml activity_diagram

title Calculator — Activity Diagram

' ── Bash CLI flow ──────────────────────────────────────────────────────────

partition "Bash CLI (main.py → src.cli.CLIHandler)" {

    start

    :Receive argv from command line;
    :setup_error_logging() → attach FileHandler to error.log;
    :Instantiate src.cli.CLIHandler();
    :CLIHandler.run(argv);

    if (argv is empty?) then (yes)
        :logger.error("[cli] missing required operation argument");
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :operation = argv[0];

    if (operation not in CLI_OPERATIONS?) then (yes)
        :logger.error("[cli] unknown operation: <op>");
        :Print "Error: unknown operation" to stderr;
        :Print usage to stderr;
        :Exit with code 1;
        stop
    endif

    :Look up (method_name, arity) from CLI_OPERATIONS;

    if (len(argv) != arity + 1?) then (yes)
        :logger.error("[cli] incorrect argument count for '...'");
        :Print "Error: requires N operand(s)" to stderr;
        :Exit with code 1;
        stop
    endif

    :Parse operand strings via _parse_operand()\n(require_int=True for factorial);

    if (ValueError during parsing?) then (yes)
        :logger.error("[cli] invalid operand for '...': <exc>");
        :Print "Error: <message>" to stderr;
        :Exit with code 1;
        stop
    endif

    :Resolve method via getattr(_calc, method_name);
    :result = method(*operands);

    if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
        :logger.error("[cli] calculation error in <op>: <exc>");
        :Print "Error: <exception message>" to stderr;
        :Exit with code 1;
        stop
    else (no)
        :Print result to stdout;
        stop
    endif

}

' ── Interactive session flow ────────────────────────────────────────────────

partition "Interactive Session (src/__main__.py → src.session.InteractiveSession)" {

    start

    :Instantiate src.session.InteractiveSession();
    :InteractiveSession.run();
    :setup_error_logging() → attach FileHandler to error.log;
    :Print "=== Interactive Calculator ===";
    :_history = [];
    :_menu_failures = 0;

    repeat : _select_mode() — up to MAX_RETRIES attempts
        :Print mode selection prompt (1=Normal / 2=Scientific);
        :Read mode choice from stdin;
        if (choice == '1'?) then (yes)
            :_mode = "normal";
        elseif (choice == '2'?) then (yes)
            :_mode = "scientific";
        else (invalid)
            :logger.error("[interactive] invalid mode choice: <choice>");
            :Print error + remaining attempts;
        endif
    repeat while (valid mode selected?)
    if (retries exhausted?) then (yes)
        :logger.error("[interactive] max retries exceeded for mode selection");
        :Print "Too many invalid mode selections. Ending session.";
        :_write_history(_history) → history.txt;
        stop
    endif

    repeat

        :_display_menu() — print mode-specific options (1–6 Normal / 1–12 Scientific), s, h, q;
        :Read user choice from stdin;

        if (choice == 'q'?) then (yes)
            :_write_history(_history) → history.txt;
            :Print "Goodbye!";
            stop
        elseif (choice == 'h'?) then (yes)
            if (_history is empty?) then (yes)
                :Print "No calculations yet.";
            else (no)
                :_show_history() — print each entry;
            endif
        elseif (choice == 's'?) then (yes)
            :_select_mode() — up to MAX_RETRIES attempts;
            if (retries exhausted?) then (yes)
                :_write_history(_history) → history.txt;
                stop
            endif
            :_mode = selected mode;
        elseif (choice not in active ops dict?) then (yes)
            :_menu_failures += 1;
            :logger.error("[interactive] invalid menu choice: <choice>");
            :Print "Invalid choice" error\n+ list of available options;
            if (_menu_failures >= MAX_RETRIES?) then (yes)
                :logger.error("[interactive] max retries exceeded for menu selection");
                :Print "Too many invalid selections.\nEnding session.";
                :_write_history(_history) → history.txt;
                stop
            else (no)
                :Print remaining attempts;
            endif
        else (valid choice)
            :_menu_failures = 0;
            :_handle_operation(choice);
            :Look up (op_name, label, arity) from active ops dict\n(NORMAL_OPERATIONS or SCIENTIFIC_OPERATIONS);
            :Resolve method via getattr(_calc, op_name);

            if (arity == 1?) then (yes)
                :_prompt_number("Enter value:", require_int)\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :a = parsed value;
                :result = method(a);
            else (arity == 2)
                :_prompt_number("Enter first value:")\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :a = parsed value;
                :_prompt_number("Enter second value:")\n[retries up to MAX_RETRIES;\nlogger.error("[interactive] invalid operand input") on each bad input];
                if (None returned — retries exhausted?) then (yes)
                    :logger.error("[interactive] max retries exceeded for operand input in <op>");
                    :Print "Too many invalid inputs.\nEnding session.";
                    :_write_history(_history) → history.txt;
                    stop
                endif
                :b = parsed value;
                :result = method(a, b);
            endif

            if (ValueError, TypeError, or\nZeroDivisionError raised?) then (yes)
                :logger.error("[interactive] calculation error in <op>: <exc>");
                :Print "Error: <exception message>";
            else (no)
                :Print "Result: <result>";
                :_history.append(_format_history_entry(op_name, operands, result));
            endif
        endif

    repeat while (session continues)

}

' ── Tkinter GUI flow ───────────────────────────────────────────────────────

partition "Tkinter GUI (src.gui.run → src.gui.CalculatorApp)" {

    start

    :src.gui.run() called;
    :Instantiate CalculatorApp();
    :__init__:\n  - Create Calculator()\n  - Create [SimpleMode(), ScientificMode()]\n  - current_mode = SimpleMode\n  - _build_ui(): build all frames and widgets\n  - _refresh_operations(): populate combobox;
    :app.mainloop() — enter tkinter event loop;

    fork
        :User selects a different mode\n(radio button click);
        :_on_mode_change();
        :current_mode = matching CalculatorMode;
        :_refresh_operations():\n  - repopulate op_combo with mode's operation names\n  - select first op; call _update_inputs(ops[0])\n  - reset result_var to "—";
    fork again
        :User selects a different operation\n(combobox selection);
        :_on_operation_change();
        :_selected_operation() → look up OperationSpec by name;
        :_update_inputs(op):\n  - set label_a to op.label_a\n  - clear entry_a\n  - if arity==2: set label_b, enable entry_b\n  - if arity==1: clear label_b, disable entry_b;
    fork again
        :User clicks "Calculate";
        :_calculate();
        :_selected_operation() → op;
        if (op is None?) then (yes)
            :return (no-op);
        endif
        :parse_number(entry_a.get(),\nrequire_int=op.require_int);
        if (ValueError?) then (yes)
            :messagebox.showerror("Input Error", "First input — <msg>");
            :return;
        endif
        if (op.arity == 2?) then (yes)
            :parse_number(entry_b.get());
            if (ValueError?) then (yes)
                :messagebox.showerror("Input Error", "Second input — <msg>");
                :return;
            endif
        endif
        :method = getattr(calculator, op.method);
        :result = method(a) or method(a, b);
        if (ValueError, ZeroDivisionError,\nor OverflowError raised?) then (yes)
            :messagebox.showerror("Calculation Error", str(exc));
            :result_var = "Error";
        else (no)
            :Format result\n(whole-number floats shown without decimal);
            :result_var = display string;
            :Append formatted entry to history list;
            :Insert entry into history_listbox;
            :Scroll listbox to end;
        endif
    fork again
        :User clicks "Clear";
        :_clear():\n  - clear entry_a\n  - clear entry_b (if enabled)\n  - reset result_var to "—";
    end fork

    :Event loop continues until window closed;
    stop

}

@enduml
