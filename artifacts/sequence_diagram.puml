@startuml sequence_diagram

title Calculator — CLI and Interactive REPL Sequence

actor User
participant "__main__\n(main)" as Main
participant "cli_main" as CLI
participant "parse_number" as Parser
participant "Calculator\n(execute)" as Calc
participant "arithmetic\n(operations)" as Arith
participant "advanced\n(operations)" as Adv
participant "math\n(stdlib)" as Math
participant "logger" as Log

User -> Main : run module (python -m src [args])
Main -> Main : logging.basicConfig(level=ERROR)

alt sys.argv has arguments — CLI mode

  Main -> CLI : cli_main(sys.argv[1:])
  note right of CLI: op = args[0]; validates op and operand count

  alt unknown operation or wrong operand count
    CLI --> User : "Error: ..." message
    CLI --> Main : return 1
    Main -> User : sys.exit(1)
  else valid operation

    alt op in BINARY_OPS (add/subtract/multiply/divide/power)
      CLI -> Parser : float(args[1]) → a
      CLI -> Parser : float(args[2]) → b
    else op in UNARY_OPS
      CLI -> Parser : float(args[1]) → a
    end

    CLI -> Calc ** : Calculator()
    CLI -> Calc : calc.execute(op, a [, b])

    note right of Calc
      execute() dispatches by op name.
      For INTEGER_OPS (factorial): calls
      _to_int_if_needed(op, a) internally;
      raises ValueError for non-whole operands.
      On success: history.append({op, operands, result}).
    end note

    alt op in BINARY_OPS (add/subtract/multiply/divide)
      Calc -> Arith : arithmetic.<op>(a, b)
      alt divide and b == 0
        Arith --> Calc : raises ZeroDivisionError
        Calc -> Log : logger.error("divide error: ...")
        Calc --> CLI : re-raises ZeroDivisionError
        CLI -> Log : logger.error("cli_main divide failed: ...")
        CLI --> User : "Error: division by zero"
        CLI --> Main : return 1
        Main -> User : sys.exit(1)
      else success
        Arith --> Calc : result
      end
    else op in UNARY_OPS / power (delegates to advanced)
      Calc -> Adv : advanced.<op>(a)
      alt ops using math stdlib (factorial/sqrt/cbrt/log10/log)
        Adv -> Math : math.factorial / sqrt / cbrt / log10 / log
        alt valid domain
          Math --> Adv : computed result
          Adv --> Calc : result
        else invalid domain (n<0, n<=0)
          Math --> Adv : raises ValueError
          Adv --> Calc : re-raises ValueError
          Calc -> Log : logger.error("<op> error: ...")
          Calc --> CLI : re-raises ValueError
          CLI -> Log : logger.error("cli_main <op> failed: ...")
          CLI --> User : "Error: <exception message>"
          CLI --> Main : return 1
          Main -> User : sys.exit(1)
        end
      else ops using ** operator (square/cube/power)
        Adv --> Calc : result
      end
    end

    alt success
      Calc -> Calc : history.append({op, operands, result})
      Calc --> CLI : result value
      CLI -> CLI : _format_result(result)
      CLI --> User : formatted result string
      CLI --> Main : return 0
      Main -> User : sys.exit(0)
    else ValueError (non-domain errors, e.g. factorial non-whole)
      Calc --> CLI : raises ValueError
      CLI -> Log : logger.error("cli_main <op> failed: ...")
      CLI --> User : "Error: <exception message>"
      CLI --> Main : return 1
      Main -> User : sys.exit(1)
    end

  end

else no arguments — Interactive REPL mode

  Main -> Calc ** : Calculator()
  Main --> User : "Welcome to the Calculator!"

  loop REPL — repeats until user quits

    Main --> User : print MENU
    User -> Main : choice (1–12, "h", or "q")

    alt choice == "q"
      Main --> User : "Goodbye!"
      note right of Main: loop exits here
    else choice == "h"
      Main -> Main : _show_history(calc)
      Main --> User : numbered history entries or "No history yet."
    else choice not in MENU_MAP
      Main --> User : "Unknown choice: ..." message
    else choice is valid (1–12)

      alt op in BINARY_OPS (add/subtract/multiply/divide/power)
        Main -> Parser : parse_number("Enter first number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float a
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
            note right of Main: run_operation catches; REPL loop continues
          end
        end

        Main -> Parser : parse_number("Enter second number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float b
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
          end
        end
      else op in UNARY_OPS
        Main -> Parser : parse_number("Enter number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float a
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
          end
        end
      end

      Main -> Calc : calc.execute(op, a [, b])

      note right of Calc
        execute() dispatches by op name.
        For INTEGER_OPS (factorial): calls
        _to_int_if_needed(op, a) internally;
        raises ValueError for non-whole operands.
        On success: history.append({op, operands, result}).
      end note

      alt op in BINARY_OPS (add/subtract/multiply/divide)
        Calc -> Arith : arithmetic.<op>(a, b)
        alt divide and b == 0
          Arith --> Calc : raises ZeroDivisionError
          Calc -> Log : logger.error("divide error: ...")
          Calc --> Main : re-raises ZeroDivisionError
          Main -> Log : logger.error("run_operation divide failed: ...")
          Main --> User : "Error: division by zero"
          note right of Main: REPL loop continues
        else success
          Arith --> Calc : result
        end
      else op in UNARY_OPS / power (delegates to advanced)
        Calc -> Adv : advanced.<op>(a)
        alt ops using math stdlib (factorial/sqrt/cbrt/log10/log)
          Adv -> Math : math.factorial / sqrt / cbrt / log10 / log
          alt valid domain
            Math --> Adv : computed result
            Adv --> Calc : result
          else invalid domain (n<0, n<=0)
            Math --> Adv : raises ValueError
            Adv --> Calc : re-raises ValueError
            Calc -> Log : logger.error("<op> error: ...")
            Calc --> Main : re-raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: <exception message>"
            note right of Main: REPL loop continues
          end
        else ops using ** operator (square/cube/power)
          Adv --> Calc : result
        end
      end

      alt success
        Calc -> Calc : history.append({op, operands, result})
        Calc --> Main : result value
        Main --> User : "Result: <value>"
      else ValueError (non-domain errors, e.g. factorial non-whole)
        Calc --> Main : raises ValueError
        Main -> Log : logger.error("run_operation <op> failed: ...")
        Main --> User : "Error: <exception message>"
      end

    end

  end

end

@enduml
