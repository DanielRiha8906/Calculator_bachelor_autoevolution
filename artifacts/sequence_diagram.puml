@startuml sequence_diagram

skinparam SequenceMessageAlign center
skinparam ParticipantFontStyle Bold

title Calculator Component Interactions

actor User
participant "__main__\n(entry point)" as Main
participant "OPERATIONS\nmap" as Ops
participant "Calculator" as Calc
participant "Python Runtime\n/ math module" as Runtime

== Interactive Session — Normal Binary Operation ==

User -> Main : python -m src
activate Main

Main -> Calc : Calculator()
activate Calc
Calc --> Main : calc instance
deactivate Calc

Main -> Main : display_menu()
Main --> User : prints 12 operations + "h. history" + "q. quit"

User -> Main : enter choice "1" (add)
Main -> Ops : lookup "1"
Ops --> Main : ("add", arity=2)

Main --> User : "Enter first number: "
User -> Main : "10"
Main -> Main : get_number("Enter first number:")
Main --> User : "Enter second number: "
User -> Main : "5"
Main -> Main : get_number("Enter second number:")

Main -> Calc : calc.add(10, 5)
activate Calc
Calc -> Runtime : 10 + 5
Runtime --> Calc : 15
Calc --> Main : 15
deactivate Calc

Main -> Main : history.append("add(10, 5) = 15")
Main --> User : "Result: 15"

== Interactive Session — Normal Unary Operation ==

User -> Main : enter choice "5" (factorial)
Main -> Ops : lookup "5"
Ops --> Main : ("factorial", arity=1)

Main --> User : "Enter integer: "
User -> Main : "5"
Main -> Main : get_number("Enter integer:", require_int=True)

Main -> Calc : calc.factorial(5)
activate Calc
Calc -> Calc : validate type (not bool, is int)
Calc -> Calc : validate value (n >= 0)
Calc -> Calc : iterate: 1*2*3*4*5
Calc --> Main : 120
deactivate Calc

Main -> Main : history.append("factorial(5) = 120")
Main --> User : "Result: 120"

== Interactive Session — History Display ==

User -> Main : enter choice "h"
Main -> Main : check history list
alt history is not empty
    Main --> User : "Session history:"\n  "add(10, 5) = 15"\n  "factorial(5) = 120"
else history is empty
    Main --> User : "No history yet."
end

== Interactive Session — Error Path (caught by main()) ==

User -> Main : enter choice "4" (divide)
Main -> Ops : lookup "4"
Ops --> Main : ("divide", arity=2)

Main -> Main : get_number() → a=1
Main -> Main : get_number() → b=0

Main -> Calc : calc.divide(1, 0)
activate Calc
Calc -> Runtime : 1 / 0
Runtime --> Calc : raise ZeroDivisionError
Calc --> Main : ZeroDivisionError propagated
deactivate Calc

Main --> User : "Error: division by zero"
note right: session continues — error is caught\nby except (ValueError, TypeError, ZeroDivisionError)

== Interactive Session — Unknown Operation Key ==

User -> Main : enter choice "99"
Main -> Ops : lookup "99"
Ops --> Main : (not found)
Main -> Main : invalid_op_attempts = 1
Main --> User : "Unknown operation '99'. Available operations: 1. add, ..."

== Interactive Session — Session Termination (max invalid operation selections) ==

User -> Main : enter choice "99" (×5 total)
note right: invalid_op_attempts increments each time\nafter 5th: >= MAX_ATTEMPTS condition met
Main --> User : "Maximum attempts reached. Ending session."
note right: session loop breaks — no _SessionExpired\njust a normal break from the while loop

== Interactive Session — Retry on Invalid Operand Input ==

User -> Main : enter choice "1" (add)
Main -> Ops : lookup "1"
Ops --> Main : ("add", arity=2)

Main --> User : "Enter first number: "
User -> Main : "abc" (invalid)
Main -> Main : get_number_with_retry() — attempt 1 of 5
note right: ValueError caught inside get_number_with_retry\nprints error + "4 attempt(s) remaining"
Main --> User : "Error: ... Please try again (4 attempt(s) remaining)."

User -> Main : "42" (valid on 2nd attempt)
Main -> Main : get_number_with_retry() — returns 42

Main --> User : "Enter second number: "
User -> Main : "abc" ×5 (all invalid)
Main -> Main : get_number_with_retry() — attempt 5 of 5
note right: remaining == 0 → prints "Maximum attempts reached.\nEnding session." then raises _SessionExpired
Main --> User : "Maximum attempts reached. Ending session."
Main -> Main : raise _SessionExpired
note right: caught by except _SessionExpired: break in main()

== Interactive Session — Quit ==

User -> Main : enter choice "q"
Main -> Main : save_history(history) → writes history.txt
Main --> User : "Goodbye!"
deactivate Main

== Bash CLI — Normal Binary Operation ==

actor Shell
participant "main.py\n(CLI entry)" as CLI

Shell -> CLI : python main.py add 5 7
activate CLI

CLI -> CLI : operation = "add"\nis_binary = True\nlen(argv) == 3 ✓
CLI -> CLI : _parse_operand("5") → 5
CLI -> CLI : _parse_operand("7") → 7

CLI -> Calc : Calculator().add(5, 7)
activate Calc
Calc -> Runtime : 5 + 7
Runtime --> Calc : 12
Calc --> CLI : 12
deactivate Calc

CLI --> Shell : stdout: "12"\nexit code: 0
deactivate CLI

== Bash CLI — Normal Unary Operation ==

Shell -> CLI : python main.py factorial 5
activate CLI

CLI -> CLI : operation = "factorial"\nis_binary = False\nlen(argv) == 2 ✓
CLI -> CLI : _parse_operand("5", require_int=True) → 5

CLI -> Calc : Calculator().factorial(5)
activate Calc
Calc -> Calc : validate type & value
Calc -> Calc : iterate: 1*2*3*4*5
Calc --> CLI : 120
deactivate Calc

CLI --> Shell : stdout: "120"\nexit code: 0
deactivate CLI

== Bash CLI — Error: Unknown Operation ==

Shell -> CLI : python main.py modulo 10 3
activate CLI
CLI -> CLI : "modulo" not in _ALL_OPS
CLI --> Shell : stderr: "Error: unknown operation 'modulo'."\nexit code: 1
deactivate CLI

== Bash CLI — Error: Wrong Argument Count ==

Shell -> CLI : python main.py add 5
activate CLI
CLI -> CLI : "add" in _BINARY_OPS\nlen(argv) == 2 ≠ 3
CLI --> Shell : stderr: "Error: 'add' requires exactly two operands."\nexit code: 1
deactivate CLI

== Bash CLI — Error: Computation Failure ==

Shell -> CLI : python main.py square_root -4
activate CLI
CLI -> CLI : operation = "square_root"\nlen(argv) == 2 ✓
CLI -> CLI : _parse_operand("-4") → -4

CLI -> Calc : Calculator().square_root(-4)
activate Calc
Calc -> Calc : guard: x < 0 → raise ValueError
Calc --> CLI : raise ValueError
deactivate Calc

CLI --> Shell : stderr: "Error: square root is not defined for negative numbers"\nexit code: 1
deactivate CLI

== Unit Tests — Calculator Direct (test_calculator.py) ==

participant "pytest\ntest suite" as Tests

Tests -> Calc : Calculator()
activate Calc
Calc --> Tests : calc instance
deactivate Calc

Tests -> Calc : calc.subtract(10, 5)
activate Calc
Calc -> Runtime : 10 - 5
Runtime --> Calc : 5
Calc --> Tests : 5
deactivate Calc

Tests -> Calc : calc.square_root(9)
activate Calc
Calc -> Calc : guard: x >= 0
Calc -> Runtime : math.sqrt(9)
Runtime --> Calc : 3.0
Calc --> Tests : 3.0
deactivate Calc

Tests -> Calc : calc.square_root(-1)
activate Calc
Calc -> Calc : guard: x < 0 → raise ValueError
Calc --> Tests : raise ValueError
deactivate Calc

Tests -> Tests : assert raises(ValueError) ✓

Tests -> Calc : calc.cube_root(-8)
activate Calc
Calc -> Calc : x < 0 → compute -(abs(-8) ** (1/3))
Calc --> Tests : -2.0
deactivate Calc

Tests -> Tests : assert cube_root(-8) == approx(-2.0) ✓

Tests -> Calc : calc.log(100)
activate Calc
Calc -> Calc : guard: x > 0
Calc -> Runtime : math.log10(100)
Runtime --> Calc : 2.0
Calc --> Tests : 2.0
deactivate Calc

Tests -> Calc : calc.ln(1)
activate Calc
Calc -> Calc : guard: x > 0
Calc -> Runtime : math.log(1)
Runtime --> Calc : 0.0
Calc --> Tests : 0.0
deactivate Calc

Tests -> Calc : calc.log(0)
activate Calc
Calc -> Calc : guard: x <= 0 → raise ValueError
Calc --> Tests : raise ValueError
deactivate Calc

Tests -> Tests : assert raises(ValueError) ✓

Tests -> Calc : calc.power(2, 10)
activate Calc
Calc -> Runtime : 2 ** 10
Runtime --> Calc : 1024
Calc --> Tests : 1024
deactivate Calc

Tests -> Tests : assert power(2, 10) == 1024 ✓

== Unit Tests — Interactive CLI (test_main.py) ==
note over Tests: 52 tests total

participant "mock\nstdin/stdout" as MockIO

Tests -> MockIO : patch builtins.input (side_effect list)
Tests -> MockIO : patch builtins.print (capture)

Tests -> Main : main()
activate Main
Main -> MockIO : input() → "8" (square_root)
Main -> Ops : lookup "8"
Ops --> Main : ("square_root", arity=1)
Main -> MockIO : input("Enter number: ") → "9"
Main -> Calc : calc.square_root(9)
activate Calc
Calc --> Main : 3.0
deactivate Calc
Main -> MockIO : print("Result: 3.0")
Main -> MockIO : input() → "q"
Main -> MockIO : print("Goodbye!")
deactivate Main

Tests -> MockIO : assert "Result: 3.0" in captured output ✓

Tests -> Main : main() [retry exhaustion test]
activate Main
note right: inputs: ["1", "abc"×5, "q"]\nMAX_ATTEMPTS=5 invalid operand inputs
Main -> MockIO : input() → "1" (add)
Main -> MockIO : input("Enter first number:") → "abc" ×5
Main -> Main : get_number_with_retry exhausted → _SessionExpired
Main --> MockIO : print("Maximum attempts reached. Ending session.")
deactivate Main
Tests -> MockIO : assert session-terminated message in output ✓

Tests -> Main : main() [max invalid op selections test]
activate Main
note right: inputs: ["99"×5]\nMAX_ATTEMPTS=5 unknown operation keys
Main -> Main : invalid_op_attempts reaches MAX_ATTEMPTS
Main -> Main : save_history([]) → writes empty history.txt
Main --> MockIO : print("Maximum attempts reached. Ending session.")
deactivate Main
Tests -> MockIO : assert session-terminated message in output ✓

Tests -> Main : main() [history display test]
activate Main
note right: inputs: ["1", "10", "5", "h", "q"]\nadd(10,5)=15 then display history
Main -> MockIO : input() → "1" (add)
Main -> MockIO : input("Enter first number: ") → "10"
Main -> MockIO : input("Enter second number: ") → "5"
Main -> Calc : calc.add(10, 5)
activate Calc
Calc --> Main : 15
deactivate Calc
Main -> Main : history.append("add(10, 5) = 15")
Main -> MockIO : input() → "h"
Main --> MockIO : print("Session history:")\nprint("  add(10, 5) = 15")
Main -> MockIO : input() → "q"
Main -> Main : save_history(["add(10, 5) = 15"]) → writes history.txt
Main --> MockIO : print("Goodbye!")
deactivate Main
Tests -> MockIO : assert "add(10, 5) = 15" in captured output ✓

== Unit Tests — Bash CLI (test_cli.py) ==

participant "pytest\ncapsys" as Capsys

Tests -> CLI : main(["add", "5", "7"])
activate CLI
CLI -> Calc : Calculator().add(5, 7)
activate Calc
Calc --> CLI : 12
deactivate Calc
CLI --> Tests : exit code 0
deactivate CLI

Tests -> Capsys : assert stdout == "12\n" ✓

Tests -> CLI : main(["square_root", "-4"])
activate CLI
CLI -> Calc : Calculator().square_root(-4)
activate Calc
Calc --> CLI : raise ValueError
deactivate Calc
CLI --> Tests : exit code 1
deactivate CLI

Tests -> Capsys : assert stderr contains "square root" ✓

Tests -> CLI : main(["add", "5"])
activate CLI
CLI -> CLI : "add" in _BINARY_OPS, len(argv) != 3
CLI --> Tests : exit code 1
deactivate CLI

Tests -> Capsys : assert stderr contains "two operands" ✓

@enduml
