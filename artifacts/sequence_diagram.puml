@startuml sequence_diagram

title Calculator — GUI, CLI, and Interactive REPL Sequence

actor User
participant "__main__\n(main)" as Main
participant "CalculatorGUI" as GUI
participant "cli_main" as CLI
participant "parse_number" as Parser
participant "Calculator\n(execute)" as Calc
participant "arithmetic\n(operations)" as Arith
participant "advanced\n(operations)" as Adv
participant "scientific\n(operations)" as Sci
participant "math\n(stdlib)" as Math
participant "logger" as Log

User -> Main : run module (python -m src [args])
Main -> Main : logging.basicConfig(level=ERROR)

alt sys.argv[1] == "--gui" — GUI mode

  note right of Main
    Lazy import: from .gui import launch_gui
    Avoids importing tkinter unless needed.
  end note

  Main -> GUI ** : launch_gui() →\n  root = tk.Tk()\n  CalculatorGUI(root)
  note right of GUI
    __init__:
      self.calc = Calculator()
      self.mode = "normal"
      self._pending_op = None
      self._first_operand = None
      self._current_input = ""
      self._build_ui()
    _build_ui builds all widget rows and
    hides sci_frame by default.
  end note
  GUI -> Calc ** : Calculator()

  Main -> GUI : root.mainloop()

  loop event loop — repeats until window closed

    alt User presses digit or "."
      User -> GUI : press_digit(digit)
      GUI -> GUI : append to _current_input
      GUI -> GUI : display_var.set(_current_input)

    else User presses binary op (+−×÷xʸ)
      User -> GUI : set_binary_op(op)
      GUI -> GUI : _first_operand = float(_current_input)
      GUI -> GUI : _pending_op = op
      GUI -> GUI : expression_var.set("a op")
      GUI -> GUI : _current_input = ""

    else User presses "="
      User -> GUI : equals()
      alt _pending_op set AND input non-empty
        GUI -> Calc : calc.execute(_pending_op, _first_operand, b)

        alt op in BINARY_OPS (add/subtract/multiply/divide)
          Calc -> Arith : arithmetic.<op>(a, b)
          alt divide and b == 0
            Arith --> Calc : raises ZeroDivisionError
            Calc -> Log : logger.error("divide error: ...")
            Calc --> GUI : re-raises ZeroDivisionError
            GUI -> Log : logger.error("GUI equals failed ...")
            GUI -> GUI : display_var = "Error"
            GUI -> GUI : expression_var = exc message
            GUI -> GUI : _current_input = ""
          else success
            Arith --> Calc : result
            Calc -> Calc : history.append({op, operands, result})
            Calc --> GUI : result
            GUI -> GUI : display_var = _format(result)
            GUI -> GUI : _current_input = _format(result)
            GUI -> GUI : _pending_op = None
          end
        else power (delegates to advanced)
          Calc -> Adv : advanced.power(a, b)
          Adv --> Calc : result
          Calc -> Calc : history.append({op, operands, result})
          Calc --> GUI : result
          GUI -> GUI : display = result; input = result
        end

      else no pending op or empty input
        GUI -> GUI : no-op
      end

    else User presses unary op (x² √ n! x³ ∛ log ln)
      User -> GUI : execute_unary(op)
      alt input non-empty
        GUI -> Calc : calc.execute(op, float(_current_input))
        note right of Calc
          For INTEGER_OPS (factorial):
          _to_int_if_needed checks whole number.
          Delegates to advanced module.
        end note
        Calc -> Adv : advanced.<op>(a)
        alt valid domain
          Adv -> Math : math.<op>(a)
          Math --> Adv : result
          Adv --> Calc : result
          Calc -> Calc : history.append({op, operands, result})
          Calc --> GUI : result
          GUI -> GUI : display = result; input = result
        else invalid domain (factorial n<0, sqrt n<0, log n<=0, ln n<=0)
          Math --> Adv : raises ValueError
          Adv --> Calc : re-raises ValueError
          Calc -> Log : logger.error("<op> error: ...")
          Calc --> GUI : re-raises ValueError
          GUI -> Log : logger.error("GUI execute_unary failed ...")
          GUI -> GUI : display_var = "Error"
        end
      else empty input
        GUI -> GUI : no-op
      end

    else User presses scientific op (sin cos tan asin acos atan sinh cosh tanh exp)
      User -> GUI : execute_unary(op)
      note right of GUI
        Scientific ops use the same execute_unary()
        path as standard unary ops — routed through
        calc.execute() to SCIENTIFIC_UNARY_OPS branch.
        No integer coercion applied.
      end note
      alt input non-empty
        GUI -> Calc : calc.execute(op, float(_current_input))
        Calc -> Sci : scientific.<op>(x)
        Sci -> Math : math.<op>(x)
        alt valid domain (asin/acos: |x|<=1; others: unrestricted)
          Math --> Sci : result
          Sci --> Calc : result
          Calc -> Calc : history.append({op, operands, result})
          Calc --> GUI : result
          GUI -> GUI : display = result; input = result
        else invalid domain (asin/acos with |x|>1)
          Math --> Sci : raises ValueError
          Sci --> Calc : re-raises ValueError
          Calc -> Log : logger.error("<op> error: ...")
          Calc --> GUI : re-raises ValueError
          GUI -> Log : logger.error("GUI execute_unary failed ...")
          GUI -> GUI : display_var = "Error"
        end
      else empty input
        GUI -> GUI : no-op
      end

    else User presses "C"
      User -> GUI : clear()
      GUI -> GUI : _current_input = ""; _pending_op = None
      GUI -> GUI : _first_operand = None
      GUI -> GUI : display_var = "0"; expression_var = ""

    else User presses "Sci"
      User -> GUI : toggle_mode()
      alt mode == "normal"
        GUI -> GUI : mode = "scientific"
        GUI -> GUI : sci_frame.grid() — show panel
      else mode == "scientific"
        GUI -> GUI : mode = "normal"
        GUI -> GUI : sci_frame.grid_remove() — hide panel
      end

    else User presses "Hist"
      User -> GUI : show_history()
      GUI -> Calc : calc.get_history()
      Calc --> GUI : list[dict] (copy)
      alt history empty
        GUI --> User : messagebox "No history yet."
      else history non-empty
        GUI --> User : messagebox numbered history entries
      end

    end

  end

else sys.argv has other arguments — CLI mode

  Main -> CLI : cli_main(sys.argv[1:])
  note right of CLI
    op = args[0]
    all_ops = UNARY_OPS | BINARY_OPS | SCIENTIFIC_UNARY_OPS
    Validates op and operand count.
    Scientific ops available without mode switching.
  end note

  alt unknown operation or wrong operand count
    CLI --> User : "Error: ..." message
    CLI --> Main : return 1
    Main -> User : sys.exit(1)
  else valid operation

    alt op in BINARY_OPS (add/subtract/multiply/divide/power)
      CLI -> Parser : float(args[1]) → a
      CLI -> Parser : float(args[2]) → b
    else op in UNARY_OPS or SCIENTIFIC_UNARY_OPS
      CLI -> Parser : float(args[1]) → a
    end

    CLI -> Calc ** : Calculator()
    CLI -> Calc : calc.execute(op, a [, b])

    note right of Calc
      execute() dispatches by op name.
      For INTEGER_OPS (factorial): calls
      _to_int_if_needed(op, a) internally;
      raises ValueError for non-whole operands.
      For SCIENTIFIC_UNARY_OPS: passes operand
      directly — no int coercion.
      On success: history.append({op, operands, result}).
    end note

    alt op in BINARY_OPS (add/subtract/multiply/divide)
      Calc -> Arith : arithmetic.<op>(a, b)
      alt divide and b == 0
        Arith --> Calc : raises ZeroDivisionError
        Calc -> Log : logger.error("divide error: ...")
        Calc --> CLI : re-raises ZeroDivisionError
        CLI -> Log : logger.error("cli_main divide failed: ...")
        CLI --> User : "Error: division by zero"
        CLI --> Main : return 1
        Main -> User : sys.exit(1)
      else success
        Arith --> Calc : result
      end
    else op in UNARY_OPS / power (delegates to advanced)
      Calc -> Adv : advanced.<op>(a)
      alt ops using math stdlib (factorial/sqrt/cbrt/log10/log)
        Adv -> Math : math.factorial / sqrt / cbrt / log10 / log
        alt valid domain
          Math --> Adv : computed result
          Adv --> Calc : result
        else invalid domain (n<0, n<=0)
          Math --> Adv : raises ValueError
          Adv --> Calc : re-raises ValueError
          Calc -> Log : logger.error("<op> error: ...")
          Calc --> CLI : re-raises ValueError
          CLI -> Log : logger.error("cli_main <op> failed: ...")
          CLI --> User : "Error: <exception message>"
          CLI --> Main : return 1
          Main -> User : sys.exit(1)
        end
      else ops using ** operator (square/cube/power)
        Adv --> Calc : result
      end
    else op in SCIENTIFIC_UNARY_OPS (delegates to scientific)
      Calc -> Sci : scientific.<op>(x)
      Sci -> Math : math.<op>(x)
      alt valid domain (asin/acos: |x| <= 1; others: unrestricted)
        Math --> Sci : computed result
        Sci --> Calc : result
      else invalid domain (asin/acos with |x| > 1)
        Math --> Sci : raises ValueError
        Sci --> Calc : re-raises ValueError
        Calc -> Log : logger.error("<op> error: ...")
        Calc --> CLI : re-raises ValueError
        CLI -> Log : logger.error("cli_main <op> failed: ...")
        CLI --> User : "Error: <exception message>"
        CLI --> Main : return 1
        Main -> User : sys.exit(1)
      end
    end

    alt success
      Calc -> Calc : history.append({op, operands, result})
      Calc --> CLI : result value
      CLI -> CLI : _format_result(result)
      CLI --> User : formatted result string
      CLI --> Main : return 0
      Main -> User : sys.exit(0)
    else ValueError (non-domain errors, e.g. factorial non-whole)
      Calc --> CLI : raises ValueError
      CLI -> Log : logger.error("cli_main <op> failed: ...")
      CLI --> User : "Error: <exception message>"
      CLI --> Main : return 1
      Main -> User : sys.exit(1)
    end

  end

else no arguments — Interactive REPL mode

  Main -> Calc ** : Calculator()
  Main -> Main : mode = "normal"
  Main --> User : "Welcome to the Calculator!"

  loop REPL — repeats until user quits

    alt mode == "normal"
      Main --> User : print MENU (12 ops + h + m + q)
    else mode == "scientific"
      Main --> User : print SCIENTIFIC_MENU (10 ops + h + m + q)
    end

    User -> Main : choice

    alt choice == "q"
      Main --> User : "Goodbye!"
      note right of Main: loop exits here
    else choice == "h"
      Main -> Main : _show_history(calc)
      Main --> User : numbered history entries or "No history yet."
    else choice == "m"
      Main -> Main : toggle mode (normal ↔ scientific)
      Main --> User : "Switched to <mode> mode."
    else choice not in active MENU_MAP
      alt mode == "normal"
        Main --> User : "Unknown choice: ... (1-12, h, m, q)"
      else mode == "scientific"
        Main --> User : "Unknown choice: ... (1-10, h, m, q)"
      end
    else choice is valid for active mode

      alt mode == "normal" — op from MENU_MAP
        note right of Main: op in BINARY_OPS or UNARY_OPS
      else mode == "scientific" — op from SCIENTIFIC_MENU_MAP
        note right of Main: op in SCIENTIFIC_UNARY_OPS
      end

      alt op in BINARY_OPS (add/subtract/multiply/divide/power)
        Main -> Parser : parse_number("Enter first number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float a
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
            note right of Main: run_operation catches; REPL loop continues
          end
        end

        Main -> Parser : parse_number("Enter second number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float b
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
          end
        end
      else op in UNARY_OPS or SCIENTIFIC_UNARY_OPS
        Main -> Parser : parse_number("Enter number: ")
        loop up to MAX_INPUT_ATTEMPTS (3) retries
          Parser --> User : prompt
          User -> Parser : raw input
          alt valid float
            Parser --> Main : float a
          else invalid — attempts remaining
            Parser --> User : "Invalid number. N attempt(s) remaining"
          else no attempts remaining
            Parser --> Main : raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: No valid number entered"
          end
        end
      end

      Main -> Calc : calc.execute(op, a [, b])

      note right of Calc
        execute() dispatches by op name.
        For INTEGER_OPS (factorial): calls
        _to_int_if_needed(op, a) internally;
        raises ValueError for non-whole operands.
        For SCIENTIFIC_UNARY_OPS: passes operand
        directly — no int coercion.
        On success: history.append({op, operands, result}).
        History is shared across normal and scientific modes.
      end note

      alt op in BINARY_OPS (add/subtract/multiply/divide)
        Calc -> Arith : arithmetic.<op>(a, b)
        alt divide and b == 0
          Arith --> Calc : raises ZeroDivisionError
          Calc -> Log : logger.error("divide error: ...")
          Calc --> Main : re-raises ZeroDivisionError
          Main -> Log : logger.error("run_operation divide failed: ...")
          Main --> User : "Error: division by zero"
          note right of Main: REPL loop continues
        else success
          Arith --> Calc : result
        end
      else op in UNARY_OPS / power (delegates to advanced)
        Calc -> Adv : advanced.<op>(a)
        alt ops using math stdlib (factorial/sqrt/cbrt/log10/log)
          Adv -> Math : math.factorial / sqrt / cbrt / log10 / log
          alt valid domain
            Math --> Adv : computed result
            Adv --> Calc : result
          else invalid domain (n<0, n<=0)
            Math --> Adv : raises ValueError
            Adv --> Calc : re-raises ValueError
            Calc -> Log : logger.error("<op> error: ...")
            Calc --> Main : re-raises ValueError
            Main -> Log : logger.error("run_operation <op> failed: ...")
            Main --> User : "Error: <exception message>"
            note right of Main: REPL loop continues
          end
        else ops using ** operator (square/cube/power)
          Adv --> Calc : result
        end
      else op in SCIENTIFIC_UNARY_OPS (delegates to scientific)
        Calc -> Sci : scientific.<op>(x)
        Sci -> Math : math.<op>(x)
        alt valid domain
          Math --> Sci : computed result
          Sci --> Calc : result
        else invalid domain (asin/acos with |x| > 1)
          Math --> Sci : raises ValueError
          Sci --> Calc : re-raises ValueError
          Calc -> Log : logger.error("<op> error: ...")
          Calc --> Main : re-raises ValueError
          Main -> Log : logger.error("run_operation <op> failed: ...")
          Main --> User : "Error: <exception message>"
          note right of Main: REPL loop continues
        end
      end

      alt success
        Calc -> Calc : history.append({op, operands, result})
        Calc --> Main : result value
        Main --> User : "Result: <value>"
      else ValueError (non-domain errors, e.g. factorial non-whole)
        Calc --> Main : raises ValueError
        Main -> Log : logger.error("run_operation <op> failed: ...")
        Main --> User : "Error: <exception message>"
      end

    end

  end

end

@enduml
