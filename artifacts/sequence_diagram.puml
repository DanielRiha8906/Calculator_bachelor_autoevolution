@startuml sequence_diagram

participant "__main__" as Main
participant "Calculator" as Calc

Main -> Main : main()
Main -> Calc : <<create>>

Main -> Calc : add(10, 5)
Calc --> Main : 15
Main -> Main : print("Addition: 15")

Main -> Calc : subtract(10, 5)
Calc --> Main : 5
Main -> Main : print("Subtraction: 5")

Main -> Calc : multiply(10, 5)
Calc --> Main : 50
Main -> Main : print("Multiplication: 50")

Main -> Calc : divide(10, 5)
alt b == 0
    Calc --> Main : ZeroDivisionError
else b != 0
    Calc --> Main : 2.0
    Main -> Main : print("Division: 2.0")
end

Main -> Calc : factorial(5)
alt n < 0 or not integer
    Calc --> Main : ValueError or TypeError
else valid n
    Calc --> Main : 120
    Main -> Main : print("Factorial: 120")
end

Main -> Calc : square(4)
Calc --> Main : 16
Main -> Main : print("Square: 16")

Main -> Calc : cube(3)
Calc --> Main : 27
Main -> Main : print("Cube: 27")

Main -> Calc : square_root(9)
alt x < 0
    Calc --> Main : ValueError
else x >= 0
    Calc --> Main : 3.0
    Main -> Main : print("Square Root: 3.0")
end

Main -> Calc : cube_root(27)
Calc --> Main : 3.0
Main -> Main : print("Cube Root: 3.0")

Main -> Calc : power(2, 10)
Calc --> Main : 1024.0
Main -> Main : print("Power: 1024.0")

Main -> Calc : log(100)
alt x <= 0
    Calc --> Main : ValueError
else x > 0
    Calc --> Main : 2.0
    Main -> Main : print("Log (base 10): 2.0")
end

Main -> Calc : ln(1)
alt x <= 0
    Calc --> Main : ValueError
else x > 0
    Calc --> Main : 0.0
    Main -> Main : print("Ln (natural log): 0.0")
end

@enduml
