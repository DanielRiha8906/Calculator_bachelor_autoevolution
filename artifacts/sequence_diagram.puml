@startuml sequence_diagram

title Calculator — Component Interaction Sequence

actor User
participant "__main__\n(main)" as Main
participant "Calculator" as Calc

User -> Main : run module

Main -> Calc : Calculator()
activate Calc

Main -> Calc : add(10, 5)
Calc --> Main : 15

Main -> Calc : subtract(10, 5)
Calc --> Main : 5

Main -> Calc : multiply(10, 5)
Calc --> Main : 50

Main -> Calc : divide(10, 5)
alt divisor != 0
    Calc --> Main : 2.0
else divisor == 0
    Calc --> Main : raises ZeroDivisionError
end

deactivate Calc

Main --> User : print results

@enduml
