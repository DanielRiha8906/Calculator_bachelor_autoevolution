@startuml sequence_diagram

title Calculator — Sequence Diagram (Interactive + CLI)

actor User
participant "main()" as Main
participant "run_interactive()" as Interactive
participant "run_cli()" as CLI
participant Calculator

User -> Main : python -m src [args...]
activate Main
Main -> Main : create Calculator()

alt no command-line args (interactive mode)
    Main -> Interactive : run_interactive(calc)
    activate Interactive
    Interactive --> User : display available operations

    loop until "quit"
        User -> Interactive : enter operation name

        alt operation == "quit"
            Interactive --> User : exit loop
        else unknown operation
            Interactive --> User : "Unknown operation '...'"
        else binary operation
            Interactive --> User : prompt "First number:"
            User -> Interactive : enter a
            Interactive --> User : prompt "Second number:"
            User -> Interactive : enter b

            alt invalid number input
                Interactive --> User : "Error: both inputs must be valid numbers."
            else valid input
                Interactive -> Calculator : <operation>(a, b)
                activate Calculator
                alt raises ValueError/TypeError
                    Calculator --> Interactive : exception
                    Interactive --> User : "Error: <message>"
                else result
                    Calculator --> Interactive : result
                    deactivate Calculator
                    Interactive --> User : "Result: <value>"
                end
            end

        else unary operation
            Interactive --> User : prompt "Number:"
            User -> Interactive : enter value

            alt invalid input
                Interactive --> User : "Error: ..."
            else valid input
                Interactive -> Calculator : <operation>(value)
                activate Calculator
                alt raises ValueError/TypeError
                    Calculator --> Interactive : exception
                    Interactive --> User : "Error: <message>"
                else result
                    Calculator --> Interactive : result
                    deactivate Calculator
                    Interactive --> User : "Result: <value>"
                end
            end
        end
    end

    deactivate Interactive

else command-line args present (CLI/bash mode)
    Main -> CLI : run_cli(argv, calc)
    activate CLI

    alt --help or empty argv
        CLI --> User : usage / help text
    else unknown operation
        CLI --> User : "Error: Unknown operation '...'"
    else binary operation with valid args
        CLI -> Calculator : <operation>(a, b)
        activate Calculator
        alt raises ValueError/TypeError
            Calculator --> CLI : exception
            CLI --> User : "Error: <message>"
        else result
            Calculator --> CLI : result
            deactivate Calculator
            CLI --> User : "Result: <value>"
        end
    else unary operation with valid arg
        CLI -> Calculator : <operation>(value)
        activate Calculator
        alt raises ValueError/TypeError
            Calculator --> CLI : exception
            CLI --> User : "Error: <message>"
        else result
            Calculator --> CLI : result
            deactivate Calculator
            CLI --> User : "Result: <value>"
        end
    else missing or invalid args
        CLI --> User : "Error: ..."
    end

    deactivate CLI
    Main -> Main : sys.exit(return_code)
end

deactivate Main

@enduml
