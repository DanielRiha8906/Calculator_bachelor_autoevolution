@startuml sequence_diagram

skinparam sequence {
    ArrowColor Black
    ActorBorderColor Black
    LifeLineBorderColor Black
    ParticipantBackgroundColor White
    ParticipantBorderColor Black
}

actor "User" as User
participant "__main__ /\ninterface.*" as Main
participant "Calculator" as Calc
participant "history.txt" as History
participant "error.log" as ErrorLog
participant "math" as Math

note over Main
  Cycle 11 modular breakdown of "Main":
  main()          → src.__main__
  cli_mode()      → src.interface.cli
  run_operation() → src.interface.interactive
  parse_number()  → src.interface.interactive
  parse_int()     → src.interface.interactive
  show_menu()     → src.interface.interactive
  file helpers    → src.interface.history
  Calculator delegates to:
    src.operations.basic (add/subtract/multiply/divide)
    src.operations.scientific (factorial/square/cube/
      square_root/cube_root/power/log/ln)
end note

User -> Main : python -m src [operation [values...]]
activate Main

alt CLI mode (args non-empty)

    Main -> Main : cli_mode(args)
    activate Main
    Main -> Main : argparse.parse_args(args)
    Main -> Calc : <<create>>
    activate Calc

    alt factorial (int arg)
        Main -> Main : validate len(values)==1
        alt len != 1
            Main -> ErrorLog : append_to_error_log("invalid_input: ...")
            Main -> User : stderr: "Error: requires 1 integer argument"\nexit(1)
        else len == 1
            Main -> Main : validate int(values[0])
            alt not a valid integer
                Main -> ErrorLog : append_to_error_log("invalid_input: ...")
                Main -> User : stderr: "Error: not a valid integer"\nexit(1)
            else valid
                Main -> Calc : execute("factorial", n)
                activate Calc
                note right of Calc : execute dispatches to\nfactorial(n) via getattr
                alt n is not int or n < 0
                    Calc --> Main : raise ValueError(...)
                    Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                    Main -> User : stderr: "Error: <message>"\nexit(1)
                else valid n
                    Calc -> Math : factorial(n)
                    Math --> Calc : n!
                    Calc --> Main : n!
                    Main -> User : stdout: print n!\nexit(0)
                end
                deactivate Calc
            end
        end

    else one-argument op (square/cube/square_root/cube_root/ln)
        Main -> Main : validate len(values)==1
        alt len != 1
            Main -> ErrorLog : append_to_error_log("invalid_input: ...")
            Main -> User : stderr: "Error: requires 1 argument"\nexit(1)
        else len == 1
            Main -> Main : validate float(values[0])
            alt not a valid number
                Main -> ErrorLog : append_to_error_log("invalid_input: ...")
                Main -> User : stderr: "Error: not a valid number"\nexit(1)
            else valid
                Main -> Calc : execute(op, float(values[0]))
                activate Calc
                note right of Calc : execute dispatches to\n<op>(a) via getattr
                alt ValueError raised (e.g. sqrt of negative, ln of non-positive)
                    Calc --> Main : raise ValueError(...)
                    Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                    Main -> User : stderr: "Error: <message>"\nexit(1)
                else success
                    Calc --> Main : result
                    Main -> User : stdout: print result\nexit(0)
                end
                deactivate Calc
            end
        end

    else two-argument op (add/subtract/multiply/divide/power/log)
        Main -> Main : validate len(values)==2
        alt len != 2
            Main -> ErrorLog : append_to_error_log("invalid_input: ...")
            Main -> User : stderr: "Error: requires 2 arguments"\nexit(1)
        else len == 2
            Main -> Main : validate float(values[0]), float(values[1])
            alt any value is not a valid number
                Main -> ErrorLog : append_to_error_log("invalid_input: ...")
                Main -> User : stderr: "Error: not a valid number"\nexit(1)
            else all valid
                Main -> Calc : execute(op, float(values[0]), float(values[1]))
                activate Calc
                note right of Calc : execute dispatches to\n<op>(a, b) via getattr
                alt ValueError raised (e.g. divide-by-zero, invalid log base)
                    Calc --> Main : raise ValueError(...)
                    Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                    Main -> User : stderr: "Error: <message>"\nexit(1)
                else success
                    Calc --> Main : result
                    Main -> User : stdout: print result\nexit(0)
                end
                deactivate Calc
            end
        end
    end

    deactivate Calc
    deactivate Main

else interactive mode (no args)

    Main -> Calc : <<create>>
    activate Calc
    Main -> History : clear_history()\n[truncate / create empty file]
    note right of Main : invalid_op_count = 0

    loop interactive menu loop

        Main -> User : show_menu()\nprint "1. add ... 12. ln  h. show history  q. quit"
        User -> Main : enter choice

        alt choice == "q"
            Main -> User : print "Goodbye!"
            note right: program exits

        else choice == "h"
            Main -> History : show_history()\n[read all lines]
            History --> Main : entry lines
            Main -> User : print "--- History ---\n  1. ...\n  2. ..."

        else invalid choice (not in OPERATIONS)
            Main -> ErrorLog : append_to_error_log("invalid_input: ...")
            Main -> Main : invalid_op_count += 1
            alt invalid_op_count >= MAX_ATTEMPTS (3)
                Main -> User : print "Too many invalid choices. Ending session."
                note right: program exits
            else attempts remaining
                Main -> User : print "Invalid choice: '<choice>'. <N> attempt(s) left."
            end

        else valid choice (dispatched via OPERATIONS dict)
            Main -> Main : invalid_op_count = 0
            Main -> Main : operation = OPERATIONS[choice]

            Main -> User : prompt for input(s)\n(parse_number / parse_int)
            note right: each invalid attempt → append_to_error_log;\neach helper retries up to MAX_ATTEMPTS=3\ntimes on invalid input, then raises\nTooManyAttemptsError
            User -> Main : numeric input(s)

            alt TooManyAttemptsError raised (input retry limit exhausted)
                Main -> User : print "Too many invalid inputs. Ending session."
                note right: program exits

            else inputs collected successfully

                group run_operation — dispatch via Calculator.execute
                    note right of Main : run_operation looks up prompts in\n_OP_PROMPTS (UI layer), then calls\ncalc.execute(operation, *args) (logic layer)

                    alt two-argument operations (add/subtract/multiply/divide/power/log)
                        Main -> Calc : execute(operation, a, b)
                        activate Calc
                        note right of Calc : dispatches to named method\nvia getattr(self, operation)
                        alt ValueError raised\n(e.g. divide-by-zero b==0,\nlog invalid a or base)
                            Calc --> Main : raise ValueError(...)
                            Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                        else success (add/subtract/multiply/power return directly;\nlog/divide route through math)
                            Calc -> Math : log(a, base) or factorial(n) [if needed]
                            Math --> Calc : result
                            Calc --> Main : result
                        end
                        deactivate Calc

                    else one-argument operations (square/cube/square_root/cube_root/ln)
                        Main -> Calc : execute(operation, a)
                        activate Calc
                        note right of Calc : dispatches to named method\nvia getattr(self, operation)
                        alt ValueError raised\n(e.g. square_root a<0,\nln a<=0)
                            Calc --> Main : raise ValueError(...)
                            Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                        else success (square/cube/cube_root return directly;\nsquare_root/ln route through math)
                            Calc -> Math : sqrt(a) or log(a) [if needed]
                            Math --> Calc : result
                            Calc --> Main : result
                        end
                        deactivate Calc

                    else factorial (int-argument operation)
                        Main -> Calc : execute("factorial", n)
                        activate Calc
                        note right of Calc : dispatches to factorial(n)\nvia getattr(self, "factorial")
                        alt n is not int or n < 0
                            Calc --> Main : raise ValueError(...)
                            Main -> ErrorLog : append_to_error_log("calculation_error: ...")
                        else valid n
                            Calc -> Math : factorial(n)
                            Math --> Calc : n!
                            Calc --> Main : n!
                        end
                        deactivate Calc
                    end
                end

                alt ValueError raised
                    Main -> User : print "Error: <message>"
                    note right: run_operation returns None;\nno history entry written
                else success
                    Main -> User : print "Result: <value>"
                    Main -> History : append_to_history(entry)\n[append "op(args) = result\n"]
                end

            end

        end

    end

    deactivate Calc

end

deactivate Main

@enduml
