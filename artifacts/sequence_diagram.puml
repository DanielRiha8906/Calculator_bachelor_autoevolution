@startuml sequence_diagram

skinparam SequenceMessageAlign center
skinparam ParticipantFontStyle Bold

title Calculator Component Interactions

actor User
participant "__main__\n(entry point)" as Main
participant "Calculator" as Calc
participant "Python Runtime\n/ math module" as Runtime

== Normal Operation (via __main__.py) ==

User -> Main : run module
activate Main

Main -> Calc : Calculator()
activate Calc
Calc --> Main : calc instance
deactivate Calc

Main -> Calc : calc.add(10, 5)
activate Calc
Calc -> Runtime : 10 + 5
Runtime --> Calc : 15
Calc --> Main : 15
deactivate Calc

Main -> Calc : calc.subtract(10, 5)
activate Calc
Calc -> Runtime : 10 - 5
Runtime --> Calc : 5
Calc --> Main : 5
deactivate Calc

Main -> Calc : calc.multiply(10, 5)
activate Calc
Calc -> Runtime : 10 * 5
Runtime --> Calc : 50
Calc --> Main : 50
deactivate Calc

Main -> Calc : calc.divide(10, 5)
activate Calc
Calc -> Runtime : 10 / 5
Runtime --> Calc : 2.0
Calc --> Main : 2.0
deactivate Calc

Main --> User : prints results
deactivate Main

== Error Path: Division by Zero ==

participant "pytest\ntest suite" as Tests

Tests -> Calc : Calculator()
activate Calc
Calc --> Tests : calc instance
deactivate Calc

Tests -> Calc : calc.divide(1, 0)
activate Calc
Calc -> Runtime : 1 / 0
Runtime --> Calc : raise ZeroDivisionError
Calc --> Tests : ZeroDivisionError propagated
deactivate Calc

Tests -> Tests : assert raises(ZeroDivisionError) ✓

== Factorial: Normal Path ==

Tests -> Calc : calc.factorial(5)
activate Calc
Calc -> Calc : validate type (not bool, is int)
Calc -> Calc : validate value (n >= 0)
Calc -> Calc : iterate: 1*2*3*4*5
Calc --> Tests : 120
deactivate Calc

Tests -> Tests : assert factorial(5) == 120 ✓

== Factorial: Error Paths ==

Tests -> Calc : calc.factorial(-1)
activate Calc
Calc -> Calc : validate value (n < 0)
Calc --> Tests : raise ValueError
deactivate Calc

Tests -> Tests : assert raises(ValueError) ✓

Tests -> Calc : calc.factorial(True)
activate Calc
Calc -> Calc : validate type (isinstance bool → reject)
Calc --> Tests : raise TypeError
deactivate Calc

Tests -> Tests : assert raises(TypeError) ✓

== Square Root: Normal and Error Paths ==

Tests -> Calc : calc.square_root(9)
activate Calc
Calc -> Calc : guard: x >= 0
Calc -> Runtime : math.sqrt(9)
Runtime --> Calc : 3.0
Calc --> Tests : 3.0
deactivate Calc

Tests -> Tests : assert square_root(9) == 3.0 ✓

Tests -> Calc : calc.square_root(-1)
activate Calc
Calc -> Calc : guard: x < 0 → raise ValueError
Calc --> Tests : raise ValueError
deactivate Calc

Tests -> Tests : assert raises(ValueError) ✓

== Cube Root: Negative Input ==

Tests -> Calc : calc.cube_root(-8)
activate Calc
Calc -> Calc : x < 0 → compute -(abs(-8) ** (1/3))
Calc --> Tests : -2.0
deactivate Calc

Tests -> Tests : assert cube_root(-8) == approx(-2.0) ✓

== Logarithm: Normal and Error Paths ==

Tests -> Calc : calc.log(100)
activate Calc
Calc -> Calc : guard: x > 0
Calc -> Runtime : math.log10(100)
Runtime --> Calc : 2.0
Calc --> Tests : 2.0
deactivate Calc

Tests -> Tests : assert log(100) == 2.0 ✓

Tests -> Calc : calc.ln(1)
activate Calc
Calc -> Calc : guard: x > 0
Calc -> Runtime : math.log(1)
Runtime --> Calc : 0.0
Calc --> Tests : 0.0
deactivate Calc

Tests -> Tests : assert ln(1) == 0.0 ✓

Tests -> Calc : calc.log(0)
activate Calc
Calc -> Calc : guard: x <= 0 → raise ValueError
Calc --> Tests : raise ValueError
deactivate Calc

Tests -> Tests : assert raises(ValueError) ✓

== Power ==

Tests -> Calc : calc.power(2, 10)
activate Calc
Calc -> Runtime : 2 ** 10
Runtime --> Calc : 1024
Calc --> Tests : 1024
deactivate Calc

Tests -> Tests : assert power(2, 10) == 1024 ✓

@enduml
