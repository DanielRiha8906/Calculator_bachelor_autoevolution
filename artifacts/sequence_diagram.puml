@startuml sequence_diagram

title Calculator — Component Interaction Sequence

actor User
participant "__main__\n(main)" as Main
participant "Calculator" as Calc
participant "math" as Math

User -> Main : run module

Main -> Calc : Calculator()
activate Calc

Main -> Calc : add(10, 5)
Calc --> Main : 15

Main -> Calc : subtract(10, 5)
Calc --> Main : 5

Main -> Calc : multiply(10, 5)
Calc --> Main : 50

Main -> Calc : divide(10, 5)
alt divisor != 0
    Calc --> Main : 2.0
else divisor == 0
    Calc --> Main : raises ZeroDivisionError
end

note over Calc, Math
  factorial delegates to stdlib
end note

Main -> Calc : factorial(n)
activate Math
Calc -> Math : math.factorial(n)
alt n >= 0
    Math --> Calc : n!
    Calc --> Main : n!
else n < 0
    Math --> Calc : raises ValueError
    Calc --> Main : raises ValueError
end
deactivate Math

deactivate Calc

Main --> User : print results

@enduml
