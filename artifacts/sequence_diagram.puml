@startuml sequence_diagram

title Calculator — Sequence Diagram

' ── Bash CLI sequence ──────────────────────────────────────────────────────

actor User as User
participant "main.py\n(entry point)" as CLI
participant "src.cli\n(CLI module)" as CLIMod
participant "CLIHandler" as Handler
participant "Calculator" as Calc
participant "error.log" as ELog

== Bash CLI Mode ==

User -> CLI : python main.py <operation> [operands]
activate CLI

CLI -> ELog : setup_error_logging()\n(attach FileHandler)
CLI -> CLIMod : import CLIHandler
CLI -> Handler : CLIHandler()
activate Handler
CLI -> Handler : run(argv)

alt no arguments
    Handler -> ELog : logger.error("[cli] missing required operation argument")
    Handler -> User : print usage to stderr\nexit code 1
else unknown operation
    Handler -> ELog : logger.error("[cli] unknown operation: ...")
    Handler -> User : "Error: unknown operation '...'" to stderr\nexit code 1
else wrong operand count
    Handler -> ELog : logger.error("[cli] incorrect argument count for '...'")
    Handler -> User : "Error: '...' requires N operand(s)" to stderr\nexit code 1
else invalid operand format (e.g. "abc", "3.5" for factorial)
    Handler -> ELog : logger.error("[cli] invalid operand for '...': ...")
    Handler -> User : "Error: ..." to stderr\nexit code 1
else valid arguments
    Handler -> Handler : _parse_operand(value, require_int)
    Handler -> Calc : Calculator() [held as _calc]
    activate Calc

    alt arity == 1
        Handler -> Calc : method(a)
    else arity == 2
        Handler -> Calc : method(a, b)
    end

    alt ValueError / TypeError / ZeroDivisionError raised
        Calc --> Handler : raises exception
        Handler -> ELog : logger.error("[cli] calculation error in <op>: ...")
        Handler -> User : "Error: <message>" to stderr\nexit code 1
    else success
        Calc --> Handler : result
        Handler -> User : print result to stdout\nexit code 0
    end

    deactivate Calc
end

deactivate Handler
deactivate CLI

' ── Interactive session sequence ───────────────────────────────────────────

== Interactive Session Mode ==

actor User
participant "src/__main__\n(entry point)" as Main
participant "src.session\n(session module)" as SessMod
participant "InteractiveSession" as Session
participant "Calculator" as Calc2
participant "history.txt" as File
participant "error.log" as ELog2

User -> Main : python -m src
activate Main

Main -> SessMod : import InteractiveSession
Main -> Session : InteractiveSession()
activate Session
Main -> Session : run()

Session -> ELog2 : setup_error_logging()\n(attach FileHandler)
Session -> Calc2 : Calculator() [held as _calc]
activate Calc2

Session -> User : "=== Interactive Calculator ==="
note right of Session : _history = []\n_menu_failures = 0

Session -> Session : _select_mode()
Session -> User : "Select mode: 1. Normal  2. Scientific"
loop up to MAX_RETRIES times
    User -> Session : mode choice
    alt choice == '1'
        Session -> Session : _mode = "normal"
    else choice == '2'
        Session -> Session : _mode = "scientific"
    else invalid input
        Session -> ELog2 : logger.error("[interactive] invalid mode choice: ...")
        Session -> User : error + remaining attempts
    end
end
alt retries exhausted
    Session -> ELog2 : logger.error("[interactive] max retries exceeded for mode selection")
    Session -> File : _write_history(_history)
    Session -> User : "Too many invalid mode selections. Ending session."
    Session -> Session : return
end

loop until user quits or retry limit reached

    Session -> Session : _display_menu()
    Session -> User : print mode-specific menu\n(Normal: 1–6, s, h, q\n Scientific: 1–12, s, h, q)
    User -> Session : enter choice

    alt choice == 'q'
        Session -> File : _write_history(_history)
        Session -> User : "Goodbye!"
        Session -> Session : break
    else choice == 'h'
        Session -> Session : _show_history()
        alt _history is empty
            Session -> User : "No calculations yet."
        else _history has entries
            Session -> User : "Session history:\n  <entry 1>\n  <entry 2>\n  ..."
        end
    else choice == 's'
        Session -> Session : _select_mode()
        Session -> User : "Select mode: 1. Normal  2. Scientific"
        loop up to MAX_RETRIES times
            User -> Session : mode choice
            alt valid choice
                Session -> Session : _mode = selected mode
            else invalid
                Session -> ELog2 : logger.error("[interactive] invalid mode choice: ...")
                Session -> User : error + remaining attempts
            end
        end
        alt retries exhausted
            Session -> File : _write_history(_history)
            Session -> User : "Too many invalid mode selections. Ending session."
            Session -> Session : break
        end
    else choice not in active ops dict (NORMAL_OPERATIONS or SCIENTIFIC_OPERATIONS)
        Session -> Session : _menu_failures += 1
        Session -> ELog2 : logger.error("[interactive] invalid menu choice: ...")
        Session -> User : "Invalid choice '...'. Available options: ..."
        alt _menu_failures >= MAX_RETRIES
            Session -> ELog2 : logger.error("[interactive] max retries exceeded for menu selection")
            Session -> File : _write_history(_history)
            Session -> User : "Too many invalid selections. Ending session."
            Session -> Session : break
        else
            Session -> User : "<N> attempt(s) remaining."
        end
    else valid choice (arity == 1) — via _handle_operation(choice)
        Session -> Session : _menu_failures = 0
        loop up to MAX_RETRIES times
            Session -> User : "Enter value:"
            User -> Session : raw input
            alt input is valid number
                Session -> Session : _prompt_number returns parsed value
            else input is invalid
                Session -> ELog2 : logger.error("[interactive] invalid operand input: ...")
                Session -> User : "Error: <message>. <N> attempt(s) remaining."
            end
        end
        alt retries exhausted (returns None)
            Session -> ELog2 : logger.error("[interactive] max retries exceeded for operand input in <op>")
            Session -> File : _write_history(_history)
            Session -> User : "Too many invalid inputs. Ending session."
            Session -> Session : break
        else valid value obtained
            Session -> Calc2 : method(a)
            alt ValueError / TypeError raised
                Calc2 --> Session : raises exception
                Session -> ELog2 : logger.error("[interactive] calculation error in <op>: ...")
                Session -> User : "Error: <message>"
            else success
                Calc2 --> Session : result
                Session -> User : "Result: <result>"
                Session -> Session : _history.append(_format_history_entry(op_name, (a,), result))
            end
        end
    else valid choice (arity == 2) — via _handle_operation(choice)
        Session -> Session : _menu_failures = 0
        loop up to MAX_RETRIES times (first operand)
            Session -> User : "Enter first value:"
            User -> Session : raw input
            alt input is valid number
                Session -> Session : _prompt_number returns parsed value
            else input is invalid
                Session -> ELog2 : logger.error("[interactive] invalid operand input: ...")
                Session -> User : "Error: <message>. <N> attempt(s) remaining."
            end
        end
        alt retries exhausted for first operand
            Session -> ELog2 : logger.error("[interactive] max retries exceeded for operand input in <op>")
            Session -> File : _write_history(_history)
            Session -> User : "Too many invalid inputs. Ending session."
            Session -> Session : break
        end
        loop up to MAX_RETRIES times (second operand)
            Session -> User : "Enter second value:"
            User -> Session : raw input
            alt input is valid number
                Session -> Session : _prompt_number returns parsed value
            else input is invalid
                Session -> ELog2 : logger.error("[interactive] invalid operand input: ...")
                Session -> User : "Error: <message>. <N> attempt(s) remaining."
            end
        end
        alt retries exhausted for second operand
            Session -> ELog2 : logger.error("[interactive] max retries exceeded for operand input in <op>")
            Session -> File : _write_history(_history)
            Session -> User : "Too many invalid inputs. Ending session."
            Session -> Session : break
        end
        Session -> Calc2 : method(a, b)
        alt ZeroDivisionError / ValueError / TypeError raised
            Calc2 --> Session : raises exception
            Session -> ELog2 : logger.error("[interactive] calculation error in <op>: ...")
            Session -> User : "Error: <message>"
        else success
            Calc2 --> Session : result
            Session -> User : "Result: <result>"
            Session -> Session : _history.append(_format_history_entry(op_name, (a, b), result))
        end
    end

end

deactivate Calc2
deactivate Session
deactivate Main

' ── Tkinter GUI sequence ───────────────────────────────────────────────────

== Tkinter GUI Mode ==

actor User
participant "src.gui\n(gui module)" as GuiMod
participant "CalculatorApp" as App
participant "CalculatorMode\n(Simple/Scientific)" as Mode
participant "OperationSpec" as OpSpec
participant "Calculator" as Calc3

User -> GuiMod : python -m src.gui\n(or python -m src.gui)
activate GuiMod

GuiMod -> App : CalculatorApp()
activate App

App -> Calc3 : Calculator() [held as self.calculator]
activate Calc3

App -> Mode : SimpleMode(), ScientificMode()
note right of App : modes = [SimpleMode(), ScientificMode()]\ncurrent_mode = SimpleMode

App -> App : _build_ui()\n(build all frames, widgets, listbox)

App -> App : _refresh_operations()
App -> Mode : current_mode.operations
Mode --> App : list[OperationSpec]
App -> App : populate op_combo with op names\nselect first op; _update_inputs(ops[0])

GuiMod -> App : app.mainloop()

note right of App : Tkinter event loop running

== User switches mode ==

User -> App : click radio button (Simple / Scientific)
App -> App : _on_mode_change()
App -> App : current_mode = matching CalculatorMode
App -> App : _refresh_operations()
App -> Mode : current_mode.operations
Mode --> App : list[OperationSpec]
App -> App : repopulate combobox\nselect first op; _update_inputs(ops[0])\nreset result_var to "—"

== User selects operation ==

User -> App : select from combobox
App -> App : _on_operation_change()
App -> App : _selected_operation()\n→ find OperationSpec by name
App -> App : _update_inputs(op)\n- set label_a\n- if arity==2: enable entry_b\n- if arity==1: disable entry_b

== User clicks Calculate ==

User -> App : click "Calculate"
App -> App : _calculate()
App -> App : _selected_operation() → op

alt op is None (no operation selected)
    App -> App : return (no-op)
else parse first operand
    App -> App : parse_number(entry_a.get(),\nrequire_int=op.require_int)
    alt ValueError
        App -> User : messagebox.showerror("Input Error", "First input — <msg>")
    end
end

alt op.arity == 2
    App -> App : parse_number(entry_b.get())
    alt ValueError
        App -> User : messagebox.showerror("Input Error", "Second input — <msg>")
    end
end

App -> Calc3 : method(a) or method(a, b)\n[resolved via getattr(calculator, op.method)]

alt ValueError / ZeroDivisionError / OverflowError
    Calc3 --> App : raises exception
    App -> User : messagebox.showerror("Calculation Error", str(exc))
    App -> App : result_var = "Error"
else success
    Calc3 --> App : result
    App -> App : format result\n(whole-number floats → int display)
    App -> App : result_var = display string
    App -> App : history.append(formatted entry)
    App -> App : history_listbox.insert(END, entry)\nhistory_listbox.see(END)
    App -> User : result shown in Result frame\nentry visible in Session History listbox
end

== User clicks Clear ==

User -> App : click "Clear"
App -> App : _clear()\n- entry_a.delete(0, END)\n- entry_b.delete(0, END) if enabled\n- result_var = "—"

deactivate Calc3
deactivate App
deactivate GuiMod

@enduml
