@startuml sequence_diagram

title Calculator — Sequence Diagram (interactive session)

actor User
participant "__main__" as Main
participant "Calculator" as Calc

User -> Main : run program
activate Main

Main -> Calc : Calculator()
activate Calc

Main -> User : "=== Interactive Calculator ==="

loop until user quits

    Main -> User : display operation menu (1–12, q)
    User -> Main : enter choice

    alt choice == 'q'
        Main -> User : "Goodbye!"
        Main -> Main : break
    else choice not in OPERATIONS
        Main -> User : "Invalid choice. Please enter a number from the list or 'q' to quit."
    else valid choice (arity == 1)
        Main -> User : "Enter value:"
        User -> Main : raw input
        Main -> Main : _parse_number(prompt, require_int)
        Main -> Calc : method(a)
        alt ValueError / TypeError raised
            Calc --> Main : raises exception
            Main -> User : "Error: <message>"
        else success
            Calc --> Main : result
            Main -> User : "Result: <result>"
        end
    else valid choice (arity == 2)
        Main -> User : "Enter first value:"
        User -> Main : raw input
        Main -> Main : _parse_number("Enter first value:")
        Main -> User : "Enter second value:"
        User -> Main : raw input
        Main -> Main : _parse_number("Enter second value:")
        Main -> Calc : method(a, b)
        alt ZeroDivisionError / ValueError / TypeError raised
            Calc --> Main : raises exception
            Main -> User : "Error: <message>"
        else success
            Calc --> Main : result
            Main -> User : "Result: <result>"
        end
    end

end

deactivate Calc
deactivate Main

@enduml
