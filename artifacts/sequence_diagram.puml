@startuml sequence_diagram

title Calculator — Interactive Session Sequence Diagram

actor User
participant "main()\nrun_session()" as Main
participant "_read_number()" as ReadNum
participant "Calculator" as Calc
participant "error_logger\ncalculator_errors.log" as ErrLog

User -> Main : python -m src
Main -> ErrLog : get_error_logger()
note right of Main : choice_failures = 0\nhistory = []

loop session (until choice == "0" or too many failures)

    Main -> User : display menu (1–12, 0 to quit, h to show history)
    User -> Main : enter menu choice

    alt choice == "0"
        Main -> Main : _write_history(history, history_file)
        Main -> User : "Goodbye!"
        note right of Main : session ends

    else choice == "h"
        alt history is empty
            Main -> User : "No history yet."
        else history has entries
            Main -> User : each history entry (e.g. "add(2, 3) = 5")
        end

    else unknown choice
        note right of Main : choice_failures += 1
        alt choice_failures >= MAX_ATTEMPTS
            Main -> ErrLog : error("Interactive: too many invalid menu choices ...")
            Main -> Main : _write_history(history, history_file)
            Main -> User : "Too many invalid choices — ending session"
            note right of Main : session ends
        else
            Main -> ErrLog : error("Interactive: invalid menu choice '...'")
            Main -> User : "Unknown choice '<x>'. Available: <list>. (N left)"
        end

    else valid choice
        note right of Main : choice_failures = 0

        alt two-operand operation (e.g. add, subtract, multiply, divide, power)
            Main -> ReadNum : _read_number("Enter first value:", error_logger)
            loop until valid float or MAX_ATTEMPTS exceeded
                ReadNum -> User : prompt
                User -> ReadNum : raw input
                alt invalid float
                    ReadNum -> ErrLog : error("Interactive: invalid number input '...'")
                    ReadNum -> User : "not a valid number (N left)"
                end
            end
            alt MAX_ATTEMPTS exceeded
                ReadNum -> Main : raise TooManyAttemptsError
                Main -> ErrLog : error("Interactive: Too many invalid inputs ...")
                Main -> Main : _write_history(history, history_file)
                Main -> User : "Too many invalid inputs — ending session"
                note right of Main : session ends
            else valid float
                ReadNum -> Main : first operand (float)
            end

            Main -> ReadNum : _read_number("Enter second value:", error_logger)
            loop until valid float or MAX_ATTEMPTS exceeded
                ReadNum -> User : prompt
                User -> ReadNum : raw input
                alt invalid float
                    ReadNum -> ErrLog : error("Interactive: invalid number input '...'")
                    ReadNum -> User : "not a valid number (N left)"
                end
            end
            alt MAX_ATTEMPTS exceeded
                ReadNum -> Main : raise TooManyAttemptsError
                Main -> ErrLog : error("Interactive: Too many invalid inputs ...")
                Main -> Main : _write_history(history, history_file)
                Main -> User : "Too many invalid inputs — ending session"
                note right of Main : session ends
            else valid float
                ReadNum -> Main : second operand (float)
            end

            Main -> Calc : method(a, b)
            alt success
                Calc -> Main : result
                Main -> Main : append entry to history
                Main -> User : "Result: <value>"
            else ZeroDivisionError (divide by zero)
                Calc -> Main : raise ZeroDivisionError
                Main -> ErrLog : error("Interactive: calculation error in divide — ...")
                Main -> User : "Error: <message>"
            end

        else single-operand non-factorial (e.g. square, square_root, log, ln, cube, cube_root)
            Main -> ReadNum : _read_number("Enter value:", error_logger)
            loop until valid float or MAX_ATTEMPTS exceeded
                ReadNum -> User : prompt
                User -> ReadNum : raw input
                alt invalid float
                    ReadNum -> ErrLog : error("Interactive: invalid number input '...'")
                    ReadNum -> User : "not a valid number (N left)"
                end
            end
            alt MAX_ATTEMPTS exceeded
                ReadNum -> Main : raise TooManyAttemptsError
                Main -> ErrLog : error("Interactive: Too many invalid inputs ...")
                Main -> Main : _write_history(history, history_file)
                Main -> User : "Too many invalid inputs — ending session"
                note right of Main : session ends
            else valid float
                ReadNum -> Main : operand (float)
            end

            Main -> Calc : method(a)
            alt success
                Calc -> Main : result
                Main -> Main : append entry to history
                Main -> User : "Result: <value>"
            else ValueError (e.g. negative square root or log of non-positive)
                Calc -> Main : raise ValueError
                Main -> ErrLog : error("Interactive: calculation error in <method> — ...")
                Main -> User : "Error: <message>"
            end

        else factorial
            Main -> ReadNum : _read_number("Enter value:", error_logger)
            loop until valid float or MAX_ATTEMPTS exceeded
                ReadNum -> User : prompt
                User -> ReadNum : raw input
                alt invalid float
                    ReadNum -> ErrLog : error("Interactive: invalid number input '...'")
                    ReadNum -> User : "not a valid number (N left)"
                end
            end
            alt MAX_ATTEMPTS exceeded
                ReadNum -> Main : raise TooManyAttemptsError
                Main -> ErrLog : error("Interactive: Too many invalid inputs ...")
                Main -> Main : _write_history(history, history_file)
                Main -> User : "Too many invalid inputs — ending session"
                note right of Main : session ends
            else valid float
                ReadNum -> Main : operand (float)
            end

            alt operand is not a whole number
                Main -> ErrLog : error("Interactive: factorial requires a whole number; got ...")
                Main -> User : "Error: factorial requires a whole number."
            else whole number
                Main -> Calc : factorial(int(n))
                alt success
                    Calc -> Main : result
                    Main -> Main : append entry to history
                    Main -> User : "Result: <value>"
                else ValueError / TypeError
                    Calc -> Main : raise error
                    Main -> ErrLog : error("Interactive: calculation error in factorial — ...")
                    Main -> User : "Error: <message>"
                end
            end

        end
    end

end

@enduml
