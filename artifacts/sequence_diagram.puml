@startuml sequence_diagram

title Calculator Usage — Sequence Diagram

actor User
participant "__main__\nmain()" as Main
participant "__main__\nrun_bash_mode()" as Bash
participant "__main__\nrun_calculator()" as Interactive
participant "Calculator" as Calc

User -> Main : python -m src [operation] [values...]

alt command-line arguments present

    Main -> Bash : run_bash_mode(argv[1:])

    alt unknown operation
        Bash -> User : "Error: Unknown operation '<name>'"
        Bash -> User : usage hint
        Bash --> Main : exit code 1
    else wrong number of values
        Bash -> User : "Error: '<op>' requires exactly N value(s)"
        Bash --> Main : exit code 1
    else non-numeric value
        Bash -> User : "Error: '<value>' is not a valid number"
        Bash --> Main : exit code 1
    else valid arguments
        Bash -> Calc : <operation>(parsed values)
        alt no error
            Calc --> Bash : result
            Bash -> User : "Result: <value>"
            Bash --> Main : exit code 0
        else ValueError
            Calc --> Bash : raise ValueError("<message>")
            Bash -> User : "Error: <message>"
            Bash --> Main : exit code 1
        end
    end

else no arguments (interactive mode)

    Main -> Interactive : run_calculator()
    Interactive -> User : Display operation menu (1-12)

    loop until quit or 'n'

        group operation choice (up to MAX_ATTEMPTS retries)
            loop attempt < MAX_ATTEMPTS
                User -> Interactive : Enter operation choice
                alt 'q'
                    Interactive -> User : "Goodbye!"
                    Interactive --> Main : return
                else valid choice
                    note right: break out of retry loop
                else invalid choice, attempts remaining
                    Interactive -> User : "Invalid choice. Please try again."
                else invalid choice, attempts exhausted
                    Interactive -> User : "Too many invalid attempts. Ending session."
                    Interactive --> Main : return
                end
            end
        end

        group operand input (up to MAX_ATTEMPTS retries)
            loop attempt < MAX_ATTEMPTS
                alt two-operand operation (add, subtract, multiply, divide, power)
                    Interactive -> User : "Enter first value:"
                    User -> Interactive : operand a
                    Interactive -> User : "Enter second value:"
                    User -> Interactive : operand b
                else one-operand operation (factorial, square, cube, sqrt, cbrt, log, ln)
                    Interactive -> User : "Enter value:"
                    User -> Interactive : operand
                end

                Interactive -> Calc : <operation>(operand(s))

                alt no error
                    Calc --> Interactive : result
                    Interactive -> User : "Result: <value>"
                    note right: break out of retry loop
                else ValueError, attempts remaining
                    Calc --> Interactive : raise ValueError("<message>")
                    Interactive -> User : "Error: <message>"
                    Interactive -> User : "Please try again."
                else ValueError, attempts exhausted
                    Calc --> Interactive : raise ValueError("<message>")
                    Interactive -> User : "Error: <message>"
                    Interactive -> User : "Too many invalid inputs. Ending session."
                    Interactive --> Main : return
                end
            end
        end

        Interactive -> User : "Continue? (y/n)"
        User -> Interactive : 'y' or 'n'

    end

    Interactive -> User : "Goodbye!"

end

@enduml
